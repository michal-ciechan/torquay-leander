    tagline: 'Baseline',
    summary: 'The site as it exists today. Top-level nav mirrors the club website: About, Training, Competitions, Gallery, Sponsors, Members Login. Most content lives on the home page with dedicated pages for the three busiest areas.',
    accent: '#f87171',
    columns: 3,
    sections: [
      {
        title: 'Home',
        description: 'Single long-scroll landing page.',
        pages: [
          { name: 'Hero + stats', desc: '"Champions in the making", founding year, swimmer count, free trial CTA.' },
