---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logo = 'https://torquayleander.co.uk/wp-content/uploads/2021/07/Logo.png';

type Page = { name: string; desc?: string };
type Section = { title: string; description?: string; pages: Page[] };
type NavItem = { label: string; children?: string[]; style?: 'cta' | 'login' };
type Variation = {
  id: string;
  title: string;
  tagline: string;
  summary: string;
  accent: string;
  columns: 2 | 3;
  sections: Section[];
  nav: NavItem[];
};

const variations: Variation[] = [
