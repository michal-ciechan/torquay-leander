<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sitemap Variations — Torquay Leander Design Hub</title>
  <style is:global>
    body.sm-page * { margin: 0; padding: 0; box-sizing: border-box; }
    body.sm-page {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0a0f1e; color: #fff;
      min-height: 100vh; padding-top: 64px;
      overflow-x: hidden;
    }
    body.sm-page a { color: inherit; text-decoration: none; }

    body.sm-page .sm-nav {
      background: rgba(12,26,46,0.98); height: 64px; padding: 0 5vw;
      display: flex; align-items: center; justify-content: space-between;
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    body.sm-page .sm-nav-brand { display: flex; align-items: center; gap: 12px; }
    body.sm-page .sm-nav-brand img { height: 36px; filter: brightness(0) invert(1); }
    body.sm-page .sm-nav-brand span { color: #fff; font-weight: 700; font-size: 0.9rem; }
    body.sm-page .sm-nav-back {
      color: rgba(255,255,255,0.65); font-size: 0.85rem; font-weight: 600;
      display: inline-flex; align-items: center; gap: 6px;
      transition: color 0.2s;
    }
    body.sm-page .sm-nav-back:hover { color: #f87171; }

    body.sm-page .sm-intro {
      max-width: 900px; margin: 56px auto 0; padding: 0 24px;
      text-align: center;
    }
    body.sm-page .sm-intro .eyebrow {
      color: rgba(255,255,255,0.45);
      font-size: 0.78rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      margin-bottom: 12px;
    }
    body.sm-page .sm-intro h1 {
      font-size: clamp(1.9rem, 4vw, 2.6rem); font-weight: 800;
      letter-spacing: -0.5px; margin-bottom: 14px;
    }
    body.sm-page .sm-intro h1 span { color: #f87171; }
    body.sm-page .sm-intro p {
      color: #94a3b8; font-size: 1.02rem; line-height: 1.7;
    }

    body.sm-page .sm-toc {
      max-width: 1200px; margin: 40px auto 0; padding: 0 24px;
      display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
    }
    body.sm-page .sm-toc a {
      background: #111827; border: 1px solid rgba(255,255,255,0.08);
      padding: 8px 14px; border-radius: 20px;
      font-size: 0.82rem; font-weight: 600;
      color: rgba(255,255,255,0.75);
      transition: border-color 0.2s, color 0.2s;
    }
    body.sm-page .sm-toc a:hover { border-color: rgba(248,113,113,0.5); color: #f87171; }

    body.sm-page .variation {
      max-width: 1280px; margin: 72px auto 0; padding: 0 24px;
      scroll-margin-top: 80px;
    }
    body.sm-page .variation-header {
      border-left: 4px solid var(--accent, #f87171);
      padding-left: 20px; margin-bottom: 28px;
    }
    body.sm-page .variation-header .tag {
      color: var(--accent, #f87171);
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      margin-bottom: 6px;
    }
    body.sm-page .variation-header h2 {
      font-size: 1.7rem; font-weight: 800;
      letter-spacing: -0.3px; margin-bottom: 10px;
    }
    body.sm-page .variation-header p {
      color: #94a3b8; font-size: 0.96rem; line-height: 1.65;
      max-width: 820px;
    }

    body.sm-page .section-grid {
      display: grid; gap: 18px;
    }
    body.sm-page .section-card {
      background: #111827;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      padding: 22px 22px 20px;
      transition: border-color 0.2s, transform 0.2s;
    }
    body.sm-page .section-card:hover {
      border-color: rgba(248,113,113,0.18);
      transform: translateY(-2px);
    }
    body.sm-page .section-card h3 {
      font-size: 1.02rem; font-weight: 800;
      letter-spacing: -0.2px; margin-bottom: 4px;
    }
    body.sm-page .section-card .section-desc {
      color: #64748b; font-size: 0.78rem;
      font-style: italic; margin-bottom: 14px;
    }
    body.sm-page .section-card ul {
      list-style: none; display: flex; flex-direction: column; gap: 10px;
    }
    body.sm-page .section-card li {
      padding: 10px 12px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 8px;
    }
    body.sm-page .section-card li .page-name {
      display: block; color: #e5e7eb;
      font-size: 0.86rem; font-weight: 700;
      margin-bottom: 3px;
    }
    body.sm-page .section-card li .page-desc {
      display: block; color: #64748b;
      font-size: 0.78rem; line-height: 1.55;
    }

    body.sm-page .nav-preview {
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      margin-bottom: 28px;
    }
    body.sm-page .nav-preview .np-meta {
      max-width: 1280px;
      margin: 0 auto 10px;
      padding: 0 24px;
      display: flex; justify-content: space-between; align-items: baseline;
    }
    body.sm-page .nav-preview .np-label {
      color: var(--accent, #f87171);
      font-size: 0.64rem; font-weight: 800;
      letter-spacing: 2px; text-transform: uppercase;
    }
    body.sm-page .nav-preview .np-hint {
      color: rgba(255,255,255,0.45);
      font-size: 0.7rem; font-style: italic;
    }
    body.sm-page .np-bar {
      background: #dc2626;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px;
      height: 70px;
      gap: 24px;
    }
    body.sm-page .np-logo {
      display: flex; align-items: center; gap: 12px;
      flex-shrink: 0;
    }
    body.sm-page .np-logo img { height: 42px; filter: brightness(0) invert(1); }
    body.sm-page .np-logo span {
      color: #fff; font-weight: 700; font-size: 1rem;
      letter-spacing: -0.3px; white-space: nowrap;
    }
    body.sm-page .np-links {
      list-style: none; display: flex; align-items: center;
      gap: 32px;
    }
    body.sm-page .np-links > li {
      position: relative;
      font-size: 0.9rem; font-weight: 500;
      color: #fff;
      white-space: nowrap;
      cursor: default;
      transition: color 0.2s;
    }
    body.sm-page .np-links > li:not(.np-btn-cta):not(.np-btn-login):hover { color: #000; }
    body.sm-page .np-links > li.has-drop::after {
      content: ' ▾'; font-size: 0.65rem;
      margin-left: 4px; opacity: 0.6;
    }
    body.sm-page .np-links > li .np-drop {
      position: absolute; top: calc(100% + 16px); left: 50%; transform: translateX(-50%);
      background: #000;
      border: 1.5px solid rgba(255,255,255,0.35);
      border-radius: 10px;
      padding: 8px 0;
      min-width: 200px;
      box-shadow: 0 16px 50px rgba(0,0,0,0.4);
      display: none; flex-direction: column;
      z-index: 200;
    }
    body.sm-page .np-links > li .np-drop::before {
      content: ''; position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
      border: 6px solid transparent; border-top: none; border-bottom-color: rgba(255,255,255,0.35);
    }
    body.sm-page .np-links > li:hover .np-drop,
    body.sm-page .np-links > li:focus-within .np-drop {
      display: flex;
    }
    body.sm-page .np-drop li {
      list-style: none;
      padding: 9px 18px;
      color: rgba(255,255,255,0.75);
      font-size: 0.82rem;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
    }
    body.sm-page .np-drop li:hover {
      background: rgba(220,38,38,0.15);
      color: #f87171;
    }
    body.sm-page .np-links .np-btn-login {
      background: #fff;
      color: #dc2626;
      padding: 6px 14px;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.9rem;
      transition: background 0.2s;
    }
    body.sm-page .np-links .np-btn-login:hover {
      background: #f0f0f0;
      color: #dc2626;
    }
    body.sm-page .np-links .np-btn-cta {
      background: #000;
      color: #fff;
      padding: 10px 22px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
      transition: background 0.2s;
    }
    body.sm-page .np-links .np-btn-cta:hover {
      background: #222;
      color: #fff;
    }

    body.sm-page .np-burger {
      display: none; flex-direction: column; justify-content: center; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 8px;
      flex-shrink: 0;
    }
    body.sm-page .np-burger span {
      display: block; width: 24px; height: 2px; background: #fff; border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }
    body.sm-page .nav-preview.is-open .np-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    body.sm-page .nav-preview.is-open .np-burger span:nth-child(2) { opacity: 0; }
    body.sm-page .nav-preview.is-open .np-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    body.sm-page .np-mobile {
      display: none;
      background: #0a0a0a;
      padding: 20px 24px 32px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    body.sm-page .nav-preview.is-open .np-mobile { display: block; }
    body.sm-page .np-mobile .mob-group { margin-bottom: 8px; }
    body.sm-page .np-mobile .mob-label {
      display: block; font-size: 0.7rem; font-weight: 700; letter-spacing: 2px;
      text-transform: uppercase; color: #f87171; padding: 16px 0 6px; opacity: 0.9;
    }
    body.sm-page .np-mobile .mob-item {
      display: block; color: rgba(255,255,255,0.82);
      padding: 10px 0; font-size: 0.95rem;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      cursor: default;
    }

    @media (max-width: 900px) {
      body.sm-page .np-bar { padding: 0 20px; }
      body.sm-page .np-links { display: none !important; }
      body.sm-page .np-burger { display: flex; }
    }

    body.sm-page .sm-footer {
      text-align: center; padding: 80px 24px 32px;
      margin-top: 80px; color: #475569;
      font-size: 0.85rem;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    @media (max-width: 700px) {
      body.sm-page .variation { padding: 0 16px; }
      body.sm-page .variation-header { padding-left: 14px; }
      body.sm-page .variation-header h2 { font-size: 1.35rem; }
    }
  </style>
</head>
<body class="sm-page">

<nav class="sm-nav">
  <a class="sm-nav-brand" href={`${base}/dev/`}>
    <img src={logo} alt="Torquay Leander" onerror="this.style.display='none'" />
    <span>Torquay Leander SC — Design Hub</span>
  </a>
  <a class="sm-nav-back" href={`${base}/dev/`}>← Back to hub</a>
</nav>

<section class="sm-intro">
  <p class="eyebrow">Information Architecture</p>
  <h1>Sitemap <span>Variations</span></h1>
  <p>Six takes on how the club site could be organised. Variation 1 is the current structure, shown as a baseline. The next five each pick a different user or strategic lens — parents, swimmer progression, community storytelling, performance positioning, or minimalism — and suggest new pages and content groupings to match.</p>
</section>

<nav class="sm-toc" aria-label="Sitemap variations">
  {variations.map((v) => (
    <a href={`#${v.id}`}>{v.title.replace('Variation ', 'V')} — {v.tagline}</a>
  ))}
</nav>

{variations.map((v) => (
  <section class="variation" id={v.id} style={`--accent: ${v.accent};`}>
    <div class="variation-header">
      <p class="tag">{v.tagline}</p>
      <h2>{v.title}</h2>
      <p>{v.summary}</p>
    </div>
    <div class="nav-preview">
      <div class="np-meta">
        <span class="np-label">Nav preview</span>
        <span class="np-hint">hover items to see children</span>
      </div>
      <div class="np-bar">
        <div class="np-logo">
          <img src={logo} alt="" onerror="this.style.display='none'" />
          <span>Torquay Leander</span>
        </div>
        <ul class="np-links">
          {v.nav.map((n) => (
            <li class={`${n.children ? 'has-drop' : ''} ${n.style === 'cta' ? 'np-btn-cta' : ''} ${n.style === 'login' ? 'np-btn-login' : ''}`.trim()} tabindex="0">
              {n.label}
              {n.children && (
                <ul class="np-drop">
                  {n.children.map((c) => (<li>{c}</li>))}
                </ul>
              )}
            </li>
          ))}
        </ul>
        <button class="np-burger" type="button" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="np-mobile">
        {v.nav.map((n) => (
          n.children ? (
            <div class="mob-group">
              <span class="mob-label">{n.label}</span>
              {n.children.map((c) => (<span class="mob-item">{c}</span>))}
            </div>
          ) : (
            <span class="mob-item">{n.label}</span>
          )
        ))}
      </div>
    </div>
    <div class="section-grid" style={`grid-template-columns: ${gridCols(v.columns)};`}>
      {v.sections.map((s) => (
        <div class="section-card">
          <h3>{s.title}</h3>
          {s.description && <p class="section-desc">{s.description}</p>}
          <ul>
            {s.pages.map((p) => (
              <li>
                <span class="page-name">{p.name}</span>
                {p.desc && <span class="page-desc">{p.desc}</span>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
))}

<footer class="sm-footer">
  Torquay Leander Swimming Club — Design exploration &copy; 2026
</footer>

<script is:inline>
  document.addEventListener('click', (e) => {
    const burger = e.target.closest('.np-burger');
    if (!burger) return;
    const preview = burger.closest('.nav-preview');
    if (preview) preview.classList.toggle('is-open');
  });
</script>

</body>
</html>
