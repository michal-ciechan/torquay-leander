---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const heading = 'Ready to Join a Squad?';
const lead = 'Get in touch to find out which squad is the right fit for you and book a free trial session with our coaching team.';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Typography — Dev</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0a0f1e; color: #e7e9f0; padding: 40px 32px 80px; min-height: 100vh; }
    .back { display: inline-block; margin-bottom: 24px; color: #8893b5; text-decoration: none; font-size: 0.85rem; }
    .back:hover { color: #fff; }
    h1.page-title { font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .subtitle { color: #8893b5; font-size: 0.9rem; margin-bottom: 44px; max-width: 680px; line-height: 1.6; }

    .sec { margin-bottom: 64px; }
    .sec > h2 { font-size: 0.95rem; font-weight: 700; color: #aab2d0; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 6px; border-bottom: 1px solid #1f2740; padding-bottom: 10px; }
    .sec > .sec-hint { color: #6f78a0; font-size: 0.82rem; margin: 10px 0 26px; max-width: 680px; line-height: 1.6; }

    .cta-demo { background: linear-gradient(135deg, #b91c1c, #dc2626); border-radius: 14px; text-align: center; padding: 44px 24px; }
    .cta-demo h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 900; letter-spacing: -0.5px; line-height: 1.2; margin-bottom: 14px; color: #fff; }
    .cta-demo p { color: rgba(255,255,255,0.9); max-width: 460px; margin: 0 auto 22px; line-height: 1.6; font-size: 0.95rem; }
    .cta-demo .btn { display: inline-block; background: #000; color: #fff; padding: 12px 26px; border-radius: 9px; font-weight: 700; font-size: 0.9rem; }
    .note { color: #8893b5; font-size: 0.82rem; margin-top: 14px; line-height: 1.6; max-width: 660px; }

    /* --- Type scale (rendered on white to match the live site) --- */
    .scale { background: #fff; color: #0a0a0a; border-radius: 14px; padding: 36px 40px; }
    .scale .row { display: grid; grid-template-columns: 160px 1fr; gap: 24px; align-items: baseline; padding: 16px 0; border-bottom: 1px solid #eef0f4; }
    .scale .row:last-child { border-bottom: 0; }
    .scale .tag { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.5px; color: #8b93a7; text-transform: uppercase; }
    .ts-h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; line-height: 1.05; }
    .ts-h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800; letter-spacing: -0.5px; }
    .ts-h3 { font-size: 1.15rem; font-weight: 800; }
    .ts-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #dc2626; }
    .ts-lead { font-size: 1rem; line-height: 1.85; color: #525b6e; }
  </style>
</head>
<body>
  <a class="back" href={`${base}/dev/`}>← Dev Hub</a>
  <h1 class="page-title">Typography</h1>
  <p class="subtitle">Type scale and the page-CTA heading treatment for the Torquay Leander site.</p>

  <section class="sec">
    <h2>CTA heading</h2>
    <p class="sec-hint">Big, bold white text on the red gradient — the standard treatment for the closing call-to-action at the foot of each page.</p>
    <div class="cta-demo">
      <h2>{heading}</h2>
      <p>{lead}</p>
      <span class="btn">Register Your Interest</span>
    </div>
    <p class="note">White on the red gradient clears WCAG AA for large text (white-on-red ≈ 4.83×), so the heading stays legible without any outline or highlight. Weight 900 with a slight negative letter-spacing keeps it punchy at the clamped size.</p>
  </section>

  <section class="sec">
    <h2>Type scale</h2>
    <p class="sec-hint">The live site type ramp, on white as it appears in production.</p>
    <div class="scale">
      <div class="row"><span class="tag">H1 / hero</span><span class="ts-h1">Building Champions</span></div>
      <div class="row"><span class="tag">H2 / section</span><span class="ts-h2">Our Squads</span></div>
      <div class="row"><span class="tag">H3 / card</span><span class="ts-h3">Development Squad</span></div>
      <div class="row"><span class="tag">Eyebrow label</span><span class="ts-label">Putting our Swimmers First!</span></div>
      <div class="row"><span class="tag">Lead / body</span><span class="ts-lead">A friendly, ambitious, and community-focused swimming club based in the heart of Torquay.</span></div>
    </div>
  </section>
</body>
</html>
