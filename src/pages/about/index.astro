---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="About Us — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <span>About Us</span>
    </div>
    <h1>About Torquay Leander Swimming Club</h1>
    <p>A friendly, ambitious, and community-focused swimming club dedicated to helping swimmers of all ages and abilities achieve their full potential.</p>
  </div>
</section>

<section class="intro-section">
  <div class="inner">
    <p class="label">Who We Are</p>
    <p class="intro-text">Torquay Leander Swimming Club is a friendly, ambitious, and community-focused swimming club based in the heart of Torquay. We are dedicated to helping swimmers of all ages and abilities achieve their full potential, whether they are swimming for fitness, personal development, or competitive success. With a strong emphasis on quality coaching, athlete development, and team spirit, we provide a safe and supportive environment where swimmers can grow in confidence both in and out of the pool.</p>
    <p class="intro-text">Our structured training pathway allows swimmers to progress at their own pace, supported by experienced coaches who are passionate about developing technique, performance, and a lifelong love of swimming. At Torquay Leander, we pride ourselves on being more than just a swimming club. We are a welcoming community where friendships are built, achievements are celebrated, and every swimmer is encouraged to be the very best version of themselves.</p>
  </div>
</section>

<section class="subpages-section">
  <div class="inner">
    <p class="label">Explore</p>
    <div class="subpages-grid">

      <a class="subpage-card" href={`${base}/about/squads/`}>
        <div class="subpage-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="subpage-body">
          <h3>Our Squads</h3>
          <p>Explore our squad structure — from Development through to Senior level. A clear pathway for every swimmer.</p>
        </div>
        <span class="subpage-arrow">›</span>
      </a>

      <a class="subpage-card" href={`${base}/membership/`}>
        <div class="subpage-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <div class="subpage-body">
          <h3>Membership</h3>
          <p>Find out about membership options, fees, and how to register with Torquay Leander Swimming Club.</p>
        </div>
        <span class="subpage-arrow">›</span>
      </a>

      <a class="subpage-card" href={`${base}/about/facilities/`}>
        <div class="subpage-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div class="subpage-body">
          <h3>Our Facilities</h3>
          <p>Learn about our training venue at Plainmoor Community Pool and the world-class equipment available to our swimmers.</p>
        </div>
        <span class="subpage-arrow">›</span>
      </a>

      <a class="subpage-card" href={`${base}/about/join/`}>
        <div class="subpage-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        </div>
        <div class="subpage-body">
          <h3>Join Us</h3>
          <p>Ready to get started? Find out what makes Torquay Leander different and register your interest today.</p>
        </div>
        <span class="subpage-arrow">›</span>
      </a>

      <a class="subpage-card" href={`${base}/about/codes-of-conduct/`}>
        <div class="subpage-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <div class="subpage-body">
          <h3>Codes of Conduct</h3>
          <p>Our expectations for swimmers, parents, and coaches — ensuring a safe, respectful environment for everyone.</p>
        </div>
        <span class="subpage-arrow">›</span>
      </a>

    </div>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; }
  .crumb a { color: var(--red); text-decoration: none; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 580px; line-height: 1.7; }

  .inner { max-width: 1200px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }

  .intro-section { background: #fff; }
  .intro-text { color: var(--muted); font-size: 1rem; line-height: 1.85; max-width: 820px; margin-bottom: 18px; }
  .intro-text:last-child { margin-bottom: 0; }

  .subpages-section { background: #f8fafc; }
  .subpages-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 44px; }
  .subpage-card {
    display: flex; align-items: flex-start; gap: 16px;
    background: #fff; border: 1.5px solid var(--border); border-radius: 16px;
    padding: 24px 20px; text-decoration: none; color: inherit;
    transition: all 0.25s; position: relative;
  }
  .subpage-card:hover { border-color: var(--red); box-shadow: 0 12px 40px rgba(220,38,38,0.1); transform: translateY(-3px); }
  .subpage-icon {
    flex-shrink: 0; width: 52px; height: 52px;
    background: var(--red-light); border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: var(--red); transition: background 0.2s;
  }
  .subpage-card:hover .subpage-icon { background: var(--red); color: #fff; }
  .subpage-body { flex: 1; }
  .subpage-body h3 { font-size: 1rem; font-weight: 800; margin-bottom: 6px; color: var(--text); }
  .subpage-body p { color: var(--muted); font-size: 0.83rem; line-height: 1.65; margin: 0; }
  .subpage-arrow { flex-shrink: 0; font-size: 1.4rem; color: var(--red); opacity: 0; transition: opacity 0.2s, transform 0.2s; transform: translateX(-4px); align-self: center; }
  .subpage-card:hover .subpage-arrow { opacity: 1; transform: translateX(0); }

  @media (max-width: 900px) {
    .subpages-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .subpages-grid { grid-template-columns: 1fr; }
  }
</style>
