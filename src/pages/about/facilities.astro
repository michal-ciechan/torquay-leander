---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Our Facilities — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <a href={`${base}/about/`}>About Us</a>
      <span>›</span>
      <span>Our Facilities</span>
    </div>
    <h1>Our Facilities</h1>
    <p>Training at Plainmoor Community Pool — a high-quality environment built for both development and competition.</p>
  </div>
</section>

<section class="venue-section">
  <div class="inner">
    <p class="label">Plainmoor Community Pool</p>
    <p class="venue-text">Our training venue is operated by Swim Torquay at Plainmoor Community Pool, providing a high-quality environment for both training and competition. The facility features a 4-lane swimming pool with a dedicated spectator viewing area, alongside male, female, and accessible changing facilities.</p>
    <p class="venue-text">We are proud to be the only swimming club in Torbay with permanent diving blocks installed on every lane for regular training use, giving our swimmers valuable experience with competition-standard starts. The pool is also equipped with full race-specification anti-wave lane ropes for gala and competition events. For the convenience of our members and families, the venue also benefits from free on-site parking, subject to vehicle registration being entered into the parking system tablet.</p>

    <div class="facility-facts">
      <div class="fact-card">
        <div class="fact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <strong>4-Lane Pool</strong>
        <span>Full-width lanes with dedicated spectator viewing area</span>
      </div>
      <div class="fact-card">
        <div class="fact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <strong>Diving Blocks on Every Lane</strong>
        <span>Only club in Torbay with permanent poolside blocks for regular training</span>
      </div>
      <div class="fact-card">
        <div class="fact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <strong>Anti-Wave Lane Ropes</strong>
        <span>Full race-specification ropes for gala and competition events</span>
      </div>
      <div class="fact-card">
        <div class="fact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <strong>Accessible Changing</strong>
        <span>Male, female, and accessible changing facilities on site</span>
      </div>
      <div class="fact-card">
        <div class="fact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <strong>Free On-Site Parking</strong>
        <span>Complimentary parking for members and families — registration required</span>
      </div>
    </div>
  </div>
</section>

<section class="equipment-section">
  <div class="inner">
    <p class="label">Competition-Grade Kit</p>
    <p class="lead">As a non-profit swimming club, we are committed to continually reinvesting back into the club, our swimmers, and our training environment.</p>
    <ul class="equipment-list">
      <li>
        <div class="eq-dot"></div>
        <span>FINA-approved backstroke ledges</span>
      </li>
      <li>
        <div class="eq-dot"></div>
        <span>Colorado Timing System</span>
      </li>
      <li>
        <div class="eq-dot"></div>
        <span>Competition-standard anti-wave lane ropes</span>
      </li>
      <li>
        <div class="eq-dot"></div>
        <span>Underwater filming equipment</span>
      </li>
      <li>
        <div class="eq-dot"></div>
        <span>Video analysis technology</span>
      </li>
    </ul>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; }
  .crumb a { color: var(--red); text-decoration: none; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 580px; line-height: 1.7; }

  .inner { max-width: 1200px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .lead { color: var(--muted); font-size: 1rem; line-height: 1.8; max-width: 700px; margin-bottom: 36px; }

  .venue-section { background: #fff; }
  .venue-text { color: var(--muted); font-size: 1rem; line-height: 1.85; max-width: 820px; margin-bottom: 18px; }

  .facility-facts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 44px; }
  .fact-card { background: #f8fafc; border: 1.5px solid var(--border); border-radius: 14px; padding: 22px 20px; transition: all 0.2s; }
  .fact-card:hover { border-color: var(--red); box-shadow: 0 8px 28px rgba(220,38,38,0.08); }
  .fact-icon { width: 44px; height: 44px; background: var(--red-light); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--red); margin-bottom: 14px; }
  .fact-card strong { display: block; font-size: 0.9rem; font-weight: 800; color: var(--text); margin-bottom: 5px; }
  .fact-card span { font-size: 0.82rem; color: var(--muted); line-height: 1.55; }

  .equipment-section { background: var(--red-light); }
  .equipment-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; max-width: 560px; }
  .equipment-list li { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: #fff; border: 1.5px solid var(--border); border-radius: 10px; font-size: 0.9rem; font-weight: 600; color: var(--text); transition: border-color 0.2s; }
  .equipment-list li:hover { border-color: var(--red); }
  .eq-dot { width: 10px; height: 10px; background: var(--red); border-radius: 50%; flex-shrink: 0; }

  @media (max-width: 900px) {
    .facility-facts { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .facility-facts { grid-template-columns: 1fr; }
  }
</style>
