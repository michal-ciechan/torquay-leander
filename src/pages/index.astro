---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Torquay Leander Swimming Club">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="12"/></svg>
        SwimMark Registered Club
      </div>
      <h1>Building Confidence, Fitness &amp; <em>Champions</em> in the Water</h1>
      <p>Torquay Leander Swimming Club — one of Devon's leading competitive swimming clubs, based in the beautiful coastal town of Torquay.</p>
      <div class="hero-btns">
        <a href="#about" class="btn-primary">About the Club</a>
        <a href="#contact" class="btn-outline">Get in Touch</a>
      </div>
    </div>
    <svg class="hero-wave" viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#dc2626"/>
    </svg>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat">
      <span class="stat-icon"><i data-lucide="users"></i></span>
      <span class="stat-num">200+</span>
      <span class="stat-label">Active Swimmers</span>
    </div>
    <div class="stat">
      <span class="stat-icon"><i data-lucide="calendar-days"></i></span>
      <span class="stat-num">30+</span>
      <span class="stat-label">Years of Excellence</span>
    </div>
    <div class="stat">
      <span class="stat-icon"><i data-lucide="calendar-check"></i></span>
      <span class="stat-num">5</span>
      <span class="stat-label">Training Sessions / Week</span>
    </div>
    <div class="stat">
      <span class="stat-icon"><i data-lucide="gift"></i></span>
      <span class="stat-num">Free</span>
      <span class="stat-label">Trial Session</span>
    </div>
  </div>

  <!-- SPONSORS -->
  <section id="sponsors" style="background:#fff; padding:48px 5vw; border-bottom:1px solid #e5e7eb;">
    <div style="max-width:1200px; margin:0 auto; text-align:center;">
      <div style="display:flex; justify-content:center; align-items:center; gap:48px; flex-wrap:wrap;">
        <img src="https://torquayleander.co.uk/wp-content/uploads/2025/08/Sparkworld-Logo.png" alt="Sparkworld" style="height:63px; object-fit:contain; filter:grayscale(1); opacity:0.55; transition:all 0.2s;" onmouseover="this.style.filter='grayscale(0)';this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)';this.style.opacity='0.55'" />
        <img src="https://torquayleander.co.uk/wp-content/uploads/2025/08/Safeheat-Homecover-Logo-MAIN-HIGH-RES.jpg" alt="Safeheat" style="height:63px; object-fit:contain; filter:grayscale(1); opacity:0.55; transition:all 0.2s;" onmouseover="this.style.filter='grayscale(0)';this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)';this.style.opacity='0.55'" />
        <img src="https://torquayleander.co.uk/wp-content/uploads/2025/09/abbey-school-logo-300x84.png" alt="Abbey School" style="height:63px; object-fit:contain; filter:grayscale(1); opacity:0.55; transition:all 0.2s;" onmouseover="this.style.filter='grayscale(0)';this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)';this.style.opacity='0.55'" />
        <img src="https://torquayleander.co.uk/wp-content/uploads/2025/09/Velocity-Plumbing-logo-300x134.png" alt="Velocity Plumbing" style="height:63px; object-fit:contain; filter:grayscale(1); opacity:0.55; transition:all 0.2s;" onmouseover="this.style.filter='grayscale(0)';this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)';this.style.opacity='0.55'" />
        <img src="https://torquayleander.co.uk/wp-content/uploads/2025/09/Stockman-Loram-300x123.jpg" alt="Stockman Loram" style="height:63px; object-fit:contain; filter:grayscale(1); opacity:0.55; transition:all 0.2s;" onmouseover="this.style.filter='grayscale(0)';this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)';this.style.opacity='0.55'" />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="trust-item"><span class="t-icon"><i data-lucide="shield-check"></i></span><span>SwimMark Registered</span></div>
    <div class="trust-item"><span class="t-icon"><i data-lucide="award"></i></span><span>Swim England Affiliated</span></div>
    <div class="trust-item"><span class="t-icon"><i data-lucide="heart"></i></span><span>Non-Profit Club</span></div>
    <div class="trust-item"><span class="t-icon"><i data-lucide="users"></i></span><span>Family Friendly</span></div>
    <div class="trust-item"><span class="t-icon"><i data-lucide="ticket"></i></span><span>Free First Session</span></div>
  </div>

  <!-- WELCOME -->
  <section class="welcome" id="about">
    <div class="welcome-inner">
      <p class="section-label">Welcome to Torquay Leander Swimming Club</p>
      <div class="welcome-body">
        <p>Founded with a passion for swimming excellence and community spirit, Torquay Leander Swimming Club is one of Devon's leading competitive swimming clubs. Based in the beautiful coastal town of Torquay, we provide a supportive and inspiring environment for swimmers to reach their potential.</p>
        <p>We coach swimming from swimmers stage 5 upwards, continuing to develop confidence, refine technique, stamina and performance to not only county but also regional and national level.</p>
        <p>Our experienced coaching team is dedicated to helping every swimmer reach their full potential through structured training, skill development, and a positive team culture.</p>
      </div>
    </div>
  </section>

  <!-- THE TORQUAY LEANDER DIFFERENCE -->
  <section class="difference" id="difference">
    <div class="difference-inner">
      <p class="section-label">The Torquay Leander Difference</p>
      <ul class="difference-list">
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>No minimum requirements for hours of training to be selected for squads</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>We understand life is busy! Swim the hours you have available across sessions throughout the week. Our competing swimmers are chosen on merit, ability and attitude — not the number of hours you commit to swim.</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>Professional qualified coaching for every training session</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>Specific annual training plan built around our Gala program. Every session is designed with the next gala in mind ensuring optimal training volume and intensity.</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>Competitive squad pathway from learn-to-race in our Development Squad, Junior Squad and through to elite swimmers in our Senior Squad</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>Friendly, inclusive, and family-focused atmosphere with high membership retention across all age groups</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>Opportunities to compete locally, regionally, and nationally</span></li>
        <li><span class="diff-check"><i data-lucide="check-circle"></i></span><span>Focus on fitness, discipline, teamwork, and personal development</span></li>
      </ul>
    </div>
  </section>

  <!-- ABOUT / MORE THAN JUST A SWIMMING CLUB -->
  <section class="about" id="community">
    <div class="about-inner">
      <div>
        <p class="section-label">More Than Just a Swimming Club</p>
        <p class="section-intro">At Torquay Leander, we pride ourselves on creating a welcoming community where swimmers form lifelong friendships, learn valuable life skills, and enjoy the sport in a safe and encouraging environment.</p>
        <p class="about-coaches-text">All of our coaches are volunteers who give up their own time to support, encourage, and develop every swimmer in the club. They are not paid for the countless hours they dedicate poolside, at competitions, and behind the scenes — they do it because they genuinely care about the swimmers and want to help each individual achieve their potential.</p>
        <p class="about-values-heading">Our club values include:</p>
        <div class="values">
          <div class="value">
            <div class="value-icon"><i data-lucide="handshake"></i></div>
            <div class="value-text">
              <strong>Respect</strong>
            </div>
          </div>
          <div class="value">
            <div class="value-icon"><i data-lucide="target"></i></div>
            <div class="value-text">
              <strong>Commitment</strong>
            </div>
          </div>
          <div class="value">
            <div class="value-icon"><i data-lucide="users-round"></i></div>
            <div class="value-text">
              <strong>Teamwork</strong>
            </div>
          </div>
          <div class="value">
            <div class="value-icon"><i data-lucide="award"></i></div>
            <div class="value-text">
              <strong>Sportsmanship</strong>
            </div>
          </div>
          <div class="value">
            <div class="value-icon"><i data-lucide="trophy"></i></div>
            <div class="value-text">
              <strong>Personal Excellence</strong>
            </div>
          </div>
        </div>
      </div>
      <div class="about-collage">
        <div class="col-img col-main">
          <img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_7634-400x284.jpg" alt="Swimmers in action" />
        </div>
        <div class="col-img col-sm1">
          <img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_7967-400x284.jpg" alt="Competitive swimmers" />
        </div>
        <div class="col-badge">
          <div class="emoji"><i data-lucide="waves"></i></div>
          <strong>Free Trial</strong>
          <span>No commitment</span>
        </div>
        <div class="col-badge2">
          <strong>200+</strong>
          <span>Happy Swimmers</span>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="gallery" id="gallery">
    <div class="gallery-inner">
      <div class="gallery-header">
        <p class="section-label">Gallery</p>
        <p class="section-intro">Moments from training, competition, and club life.</p>
      </div>
      <div class="photo-grid">
        <div class="photo-item wide tall"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_8030-400x284.jpg" alt="" /></div>
        <div class="photo-item"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_6586-400x284.jpg" alt="" /></div>
        <div class="photo-item"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_7998-400x284.jpg" alt="" /></div>
        <div class="photo-item"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_8181-400x284.jpg" alt="" /></div>
        <div class="photo-item"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_7634-400x284.jpg" alt="" /></div>
        <div class="photo-item"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/06/DSC_7480-400x284.jpg" alt="" /></div>
        <div class="photo-item"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_8904-400x284.jpg" alt="" /></div>
      </div>
    </div>
  </section>

  <!-- FACEBOOK FEED -->
  <section class="fb-section" id="news">
    <div class="fb-inner">
      <div class="fb-header">
        <div>
          <p class="section-label">Latest from Facebook</p>
        </div>
        <a class="fb-follow" href="https://www.facebook.com/TorquayLeanderSwimmingClub" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Follow on Facebook
        </a>
      </div>
      <div class="fb-posts">
        <div class="fb-post">
          <div class="fb-post-img"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_8030-400x284.jpg" alt="" /></div>
          <div class="fb-post-body">
            <div class="fb-post-header">
              <div class="fb-avatar"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/07/Logo.png" alt="" style="filter:brightness(0) invert(1); background:#0a0a0a; padding:4px;" /></div>
              <div class="fb-meta"><strong>Torquay Leander Swimming Club</strong><span>1 week ago</span></div>
            </div>
            <p>3rd and final round! Let's Go Torquay! 👏👏👏 What a performance from all our swimmers today — so proud of every one of them.</p>
            <a class="fb-post-link" href="https://www.facebook.com/TorquayLeanderSwimmingClub" target="_blank">View on Facebook →</a>
          </div>
        </div>
        <div class="fb-post">
          <div class="fb-post-img"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_7899-400x284.jpg" alt="" /></div>
          <div class="fb-post-body">
            <div class="fb-post-header">
              <div class="fb-avatar"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/07/Logo.png" alt="" style="filter:brightness(0) invert(1); background:#0a0a0a; padding:4px;" /></div>
              <div class="fb-meta"><strong>Torquay Leander Swimming Club</strong><span>2 weeks ago</span></div>
            </div>
            <p>Brilliant results at the Devon County Championships this weekend. Congratulations to all our swimmers who competed and gave their absolute best! 🏆</p>
            <a class="fb-post-link" href="https://www.facebook.com/TorquayLeanderSwimmingClub" target="_blank">View on Facebook →</a>
          </div>
        </div>
        <div class="fb-post">
          <div class="fb-post-img"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_8181-400x284.jpg" alt="" /></div>
          <div class="fb-post-body">
            <div class="fb-post-header">
              <div class="fb-avatar"><img src="https://torquayleander.co.uk/wp-content/uploads/2021/07/Logo.png" alt="" style="filter:brightness(0) invert(1); background:#0a0a0a; padding:4px;" /></div>
              <div class="fb-meta"><strong>Torquay Leander Swimming Club</strong><span>3 weeks ago</span></div>
            </div>
            <p>Welcome to all our new members joining us this term! 🌊 If you're interested in a free trial, get in touch — we'd love to have you join the Leander family.</p>
            <a class="fb-post-link" href="https://www.facebook.com/TorquayLeanderSwimmingClub" target="_blank">View on Facebook →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- JOIN: form + map -->
  <section class="join" id="contact">
    <div class="join-inner">
      <div class="join-head">
        <p class="section-label">Join Us</p>
        <p class="section-intro" style="margin:12px auto 0;">Whether your goal is to improve fitness, compete at a higher level, or simply enjoy swimming as part of a great community, Torquay Leander Swimming Club welcomes you.</p>
        <p class="join-sub-intro">We are always excited to hear from new swimmers and families interested in becoming part of the club.</p>
      </div>
      <div class="join-grid">
        <div class="join-card join-form-card">
          <h3>Ready to Dive In?</h3>
          <p class="join-form-intro">Interested in coming for a free trial? Please register your interest below. We understand it's not just about your ability but also the environment you train in — feeling comfortable with your fellow swimmers, coaches and surroundings is the best way to reach your potential.</p>
          <input class="form-field" type="text" placeholder="Name of Swimmer" />
          <label class="form-field-label">Date of Birth</label>
          <input class="form-field form-field-date" type="date" />
          <input class="form-field" type="text" placeholder="Swim level of swimmer (Stage 5 minimum)" />
          <input class="form-field" type="text" placeholder="Name of parent / guardian" />
          <input class="form-field" type="tel" placeholder="Contact number" />
          <input class="form-field" type="email" placeholder="Email address" />
          <button class="form-submit" onclick="window.location='mailto:torquayleander@hotmail.com'">Send My Interest</button>
        </div>
        <div class="join-card join-map-card">
          <div class="join-map-embed">
            <div id="join-map"></div>
          </div>
          <div class="join-map-foot">
            <strong>Swim Torquay — Plainmoor</strong>
            <p>We train at Swim Torquay in the Plainmoor area of Torquay, Devon. Parking and spectator access available on session nights.</p>
            <a href="https://www.google.com/maps?q=Swim+Torquay+Plainmoor" target="_blank" rel="noopener">Open in Google Maps →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function initJoinMap() {
      const location = { lat: 50.4800, lng: -3.5350 };
      const map = new google.maps.Map(document.getElementById('join-map'), {
        center: location,
        zoom: 16,
        zoomControl: true,
        mapTypeControl: false,
        streetViewControl: true,
        fullscreenControl: true,
      });
      new google.maps.Marker({ position: location, map, title: 'Swim Torquay — Plainmoor' });
    }
  </script>
  <script is:inline async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCFulZw8ODr_AwZv7qCFLTqvPEryJrCbuw&loading=async&callback=initJoinMap"></script>
</BaseLayout>
