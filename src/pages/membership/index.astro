---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnderConstruction from '../../components/UnderConstruction.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Membership — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <span>Membership</span>
    </div>
    <h1>Membership</h1>
    <p>Join one of Devon's leading competitive swimming clubs. We offer flexible membership options to suit all commitment levels — with no minimum training hours required for squad selection.</p>
  </div>
</section>

<section class="mem-intro">
  <div class="inner">
    <div class="mem-cards">
      <a class="mem-card" href={`${base}/membership/costs/`}>
        <div class="mem-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/><path d="M9 10h6"/><path d="M9 14h6"/></svg>
        </div>
        <div class="mem-card-body">
          <h3>Membership Costs</h3>
          <p>View current annual and monthly fee structures for all age groups and squad levels.</p>
          <span class="mem-link">View costs →</span>
        </div>
      </a>
      <a class="mem-card" href={`${base}/membership/benefits/`}>
        <div class="mem-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="mem-card-body">
          <h3>Membership Benefits</h3>
          <p>Discover what's included in your membership — coaching, competitions, kit and more.</p>
          <span class="mem-link">See benefits →</span>
        </div>
      </a>
      <a class="mem-card" href={`${base}/about/join/`}>
        <div class="mem-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        </div>
        <div class="mem-card-body">
          <h3>Join Us</h3>
          <p>Ready to get started? Find out how to register and book your free trial session.</p>
          <span class="mem-link">Join now →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<UnderConstruction
  title="Membership Details Coming Soon"
  message="We're currently updating our membership pages with the latest costs and benefits. Contact us at torquayleander@hotmail.com for current pricing."
/>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 600px; line-height: 1.7; }

  .mem-intro { background: #fff; padding: 72px 5vw; }
  .inner { max-width: 1200px; margin: 0 auto; }

  .mem-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .mem-card {
    display: flex; align-items: flex-start; gap: 18px;
    border: 1.5px solid var(--border); border-radius: 16px; padding: 28px 24px;
    text-decoration: none; color: inherit; transition: all 0.25s;
  }
  .mem-card:hover { border-color: var(--red); box-shadow: 0 12px 40px rgba(220,38,38,0.1); transform: translateY(-3px); }
  .mem-icon {
    flex-shrink: 0; width: 52px; height: 52px;
    background: var(--red-light); border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: var(--red);
  }
  .mem-card-body h3 { font-size: 1rem; font-weight: 800; margin-bottom: 6px; }
  .mem-card-body p { color: var(--muted); font-size: 0.85rem; line-height: 1.6; margin-bottom: 12px; }
  .mem-link { font-size: 0.82rem; font-weight: 700; color: var(--red); }

  @media (max-width: 768px) {
    .mem-cards { grid-template-columns: 1fr; }
    .mem-intro { padding: 48px 20px; }
  }
</style>
