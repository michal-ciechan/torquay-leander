---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const benefits = [
  {
    title: 'Professional qualified coaching',
    body: 'Every session is led by a professionally qualified coach. Swimmers follow a structured annual training plan built around our gala programme.',
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  },
  {
    title: 'A competitive squad pathway',
    body: 'A clear progression from learn-to-race through to senior level, with opportunities to compete locally, at county, and at regional level.',
    icon: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
  },
  {
    title: 'A friendly, family-focused community',
    body: 'Generations of families have swum at Torquay Leander. We are a friendly, approachable, fun yet competitive club where every swimmer is welcome.',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    title: 'Swim England membership included',
    body: 'Your club membership includes Swim England registration — covering insurance and enabling your swimmer to enter licensed competitions.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    title: 'In-house galas &amp; events',
    body: 'Ribbon galas, club championships and our annual awards night give swimmers a chance to compete, celebrate, and get to know the club.',
    icon: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>',
  },
  {
    title: 'Exclusive retailer discounts',
    body: 'Members save on swim gear and equipment through exclusive discount codes at a range of popular online retailers — see below.',
    icon: '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>',
  },
];

const retailers = ['Pro-Swimwear', 'Allens Swimwear', 'Maru', 'Sporty Swim', 'Ness Swimwear', 'Wyvern Swimwear'];
---
<BaseLayout title="Membership Benefits — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <a href={`${base}/membership/`}>Membership</a>
      <span>›</span>
      <span>Benefits</span>
    </div>
    <h1>Membership Benefits</h1>
    <p>Find out everything that's included when you join Torquay Leander — from expert coaching and competition entry to club kit and community events.</p>
  </div>
</section>

<section class="intro">
  <div class="inner">
    <p class="label">Why Join Us</p>
    <p class="intro-text">Being a member of Torquay Leander comes with fantastic benefits. You gain access to top-notch coaching and a supportive community, the chance to compete at every level, and exclusive savings on the gear you need — it's just one of the many ways we support our members both in and out of the pool.</p>
  </div>
</section>

<section class="benefits">
  <div class="inner">
    <div class="benefit-grid">
      {benefits.map((b) => (
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={b.icon} />
          </div>
          <h3 set:html={b.title} />
          <p>{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="discounts">
  <div class="inner discounts-inner">
    <p class="label">Member Discounts</p>
    <h2>Exclusive savings on swim gear</h2>
    <p class="discounts-text">Our members enjoy exclusive discounts at a range of popular online swim retailers, making it easier to access quality swimwear, equipment and accessories at a better price.</p>
    <div class="retailer-chips">
      {retailers.map((r) => <span class="chip">{r}</span>)}
    </div>
    <div class="codes-callout">
      <span class="codes-icon">🔑</span>
      <p>Discount codes are available to members in the <strong>Club Organiser app</strong>, under <strong>Documents → TL Discount Codes</strong>.</p>
    </div>
  </div>
</section>

<section class="cta-band">
  <div class="inner cta-inner">
    <h2>Ready to join Torquay Leander?</h2>
    <p>Arrange a free trial session and find out what makes our club special.</p>
    <a class="cta-btn" href={`${base}/about/join/`}>Join Us →</a>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; flex-wrap: wrap; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 580px; line-height: 1.7; }

  .inner { max-width: 1100px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }

  .intro { background: #fff; padding: 72px 5vw 40px; }
  .intro-text { color: var(--muted); font-size: 1.05rem; line-height: 1.85; max-width: 820px; }

  .benefits { background: #fff; padding: 24px 5vw 72px; }
  .benefit-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .benefit-card {
    border: 1.5px solid var(--border); border-radius: 16px; padding: 28px 24px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .benefit-card:hover { border-color: var(--red); box-shadow: 0 12px 40px rgba(220,38,38,0.08); transform: translateY(-3px); }
  .benefit-icon {
    width: 48px; height: 48px; border-radius: 12px; background: var(--red-light);
    display: flex; align-items: center; justify-content: center; color: var(--red);
    margin-bottom: 16px;
  }
  .benefit-card h3 { font-size: 1rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .benefit-card p { color: var(--muted); font-size: 0.86rem; line-height: 1.7; margin: 0; }

  .discounts { background: #f8fafc; padding: 72px 5vw; }
  .discounts-inner { max-width: 820px; }
  .discounts h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }
  .discounts-text { color: var(--muted); font-size: 1rem; line-height: 1.8; margin-bottom: 24px; }
  .retailer-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px; }
  .chip {
    background: #fff; border: 1.5px solid var(--border); border-radius: 999px;
    padding: 9px 18px; font-size: 0.85rem; font-weight: 700; color: var(--text);
  }
  .codes-callout {
    display: flex; align-items: center; gap: 14px;
    background: var(--red-light); border: 1.5px solid #fecaca; border-radius: 12px;
    padding: 18px 22px; max-width: 640px;
  }
  .codes-icon { font-size: 1.5rem; flex-shrink: 0; }
  .codes-callout p { color: var(--text); font-size: 0.92rem; line-height: 1.6; margin: 0; }

  .cta-band { background: linear-gradient(135deg, var(--red-dark), var(--red)); padding: 64px 5vw; text-align: center; }
  .cta-inner { max-width: 600px; }
  .cta-band h2 { color: #fff; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin-bottom: 12px; }
  .cta-band p { color: rgba(255,255,255,0.85); font-size: 1rem; margin-bottom: 28px; }
  .cta-btn {
    display: inline-block; background: #000; color: #fff; text-decoration: none;
    padding: 14px 32px; border-radius: 10px; font-weight: 700; font-size: 0.95rem;
    transition: transform 0.2s, background 0.2s;
  }
  .cta-btn:hover { background: #222; transform: translateY(-2px); }

  @media (max-width: 900px) {
    .benefit-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .benefit-grid { grid-template-columns: 1fr; }
    .intro, .benefits, .discounts, .cta-band { padding-left: 20px; padding-right: 20px; }
  }
</style>
