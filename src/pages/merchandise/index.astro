---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnderConstruction from '../../components/UnderConstruction.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Club Merchandise — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <span>Club Merchandise</span>
    </div>
    <h1>Club Merchandise</h1>
    <p>Training equipment, clothing, and club kit can be purchased through our official club shop, powered by Wyvern Swimming.</p>
  </div>
</section>

<UnderConstruction
  title="Shop Coming Soon"
  message="We're currently setting up our club shop with Wyvern Swimming. Check back soon to browse and purchase club kit, training equipment, and clothing."
/>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fafafa; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 560px; line-height: 1.7; }
</style>
