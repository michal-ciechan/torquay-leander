---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const startSteps = [
  { n: 1, title: 'Take your place', text: 'Swimmers take their place on the starting block or platform — on the deck, or in the water for backstroke. Competitors should remove all excess clothing except their competition swimwear.' },
  { n: 2, title: 'Long whistle', text: 'A long whistle tells swimmers to get ready. The referee stretches out an arm — this signals that the swimmers are now under the starter\'s control.' },
  { n: 3, title: '"Take your marks"', text: 'On the starter\'s command "take your marks", swimmers assume the starting position — one foot in front of the starting platform, or one hand on the wall for those starting in the water — and wait.' },
  { n: 4, title: 'The start signal', text: 'When the starting signal sounds, the race begins. The referee initiates each heat and the final race using short blasts on a whistle to give signals to swimmers.' },
];

const strokes = [
  { icon: '🦋', name: 'Butterfly', text: 'Both arms recover over the water together, with a simultaneous dolphin kick.' },
  { icon: '🔙', name: 'Backstroke', text: 'Swum on the back throughout the race — swimmers push off on their back and stay there.' },
  { icon: '🐸', name: 'Breaststroke', text: 'Simultaneous arm and leg movements, with the body kept on the breast.' },
  { icon: '🏊', name: 'Freestyle', text: 'Any stroke may be used — almost all swimmers choose front crawl for speed.' },
];
---
<BaseLayout title="Competition Guide — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <a href={`${base}/galas/`}>Galas &amp; Competitions</a>
      <span>›</span>
      <span>Competition Guide</span>
    </div>
    <h1>Competition Guide</h1>
    <p>Everything you need to know before your first meet with Torquay Leander.</p>
  </div>
</section>

<section class="intro">
  <div class="inner intro-inner">
    <p class="label">Your First Gala</p>
    <p class="intro-text">Entering competitions for the first time can be quite daunting — both for the swimmer and for parents. At Torquay Leander we're here to support you as much as possible, so if you have any questions please do ask. This guide brings together the information you'll find most useful, especially as a new swimming parent.</p>
    <div class="reassure">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
      <span>Don't worry about getting everything right — your coach will guide your swimmer through the day. The most important thing is to take part and enjoy it.</span>
    </div>
  </div>
</section>

<section class="rules">
  <div class="inner">
    <p class="label">Race Rules</p>
    <h2>How a swimming race works</h2>
    <p class="rules-text">A referee initiates each swim heat and the final race, using a series of short blasts on a whistle to signal to swimmers. Races follow the Swim England (ASA) rules and regulations, which govern how each swimmer must start, turn and finish.</p>
  </div>
</section>

<section class="start">
  <div class="inner">
    <p class="label">Starting a Race</p>
    <div class="start-grid">
      {startSteps.map((s) => (
        <div class="start-card">
          <div class="start-num">{s.n}</div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="strokes">
  <div class="inner">
    <p class="label">Strokes, Turns &amp; Finishes</p>
    <h2>The four competitive strokes</h2>
    <p class="rules-text">There are four swimming styles recognised in competition. "Stroke" refers to how the swimmer performs the style — and each has its own rules for how to turn at the end of a lap and how to finish the race.</p>
    <div class="stroke-grid">
      {strokes.map((s) => (
        <div class="stroke-card">
          <span class="stroke-icon">{s.icon}</span>
          <strong>{s.name}</strong>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="next">
  <div class="inner next-inner">
    <h2>Ready to race?</h2>
    <p>Our Club Championships are a great first competition — fun, friendly, and held in a familiar pool. Speak to your coach about which events to enter.</p>
    <div class="next-btns">
      <a class="btn-solid" href={`${base}/galas/club-championships/`}>Club Championships</a>
      <a class="btn-ghost" href={`${base}/galas/ribbon-gala/`}>Ribbon Gala</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; flex-wrap: wrap; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 580px; line-height: 1.7; }

  .inner { max-width: 1100px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
  h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }

  .intro { background: #fff; padding: 72px 5vw 48px; }
  .intro-inner { max-width: 820px; }
  .intro-text { color: var(--muted); font-size: 1.02rem; line-height: 1.85; margin-bottom: 24px; }
  .reassure {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--red-light); border: 1.5px solid #fecaca; border-radius: 12px;
    padding: 18px 22px; color: var(--text); font-size: 0.92rem; line-height: 1.65;
  }
  .reassure svg { flex-shrink: 0; margin-top: 2px; color: var(--red); }

  .rules { background: #fff; padding: 24px 5vw 16px; }
  .rules-text { color: var(--muted); font-size: 1rem; line-height: 1.8; max-width: 820px; }

  .start { background: #fff; padding: 40px 5vw 72px; }
  .start-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .start-card { border: 1.5px solid var(--border); border-radius: 16px; padding: 26px 22px; }
  .start-num {
    width: 38px; height: 38px; border-radius: 10px; background: var(--red); color: #fff;
    display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.1rem;
    margin-bottom: 16px;
  }
  .start-card h3 { font-size: 0.95rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .start-card p { color: var(--muted); font-size: 0.84rem; line-height: 1.65; margin: 0; }

  .strokes { background: #f8fafc; padding: 72px 5vw; }
  .stroke-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-top: 32px; }
  .stroke-card { background: #fff; border: 1.5px solid var(--border); border-radius: 16px; padding: 26px 22px; }
  .stroke-icon { font-size: 1.8rem; display: block; margin-bottom: 12px; }
  .stroke-card strong { display: block; font-size: 1rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .stroke-card p { color: var(--muted); font-size: 0.84rem; line-height: 1.65; margin: 0; }

  .next { background: var(--black); padding: 72px 5vw; text-align: center; }
  .next-inner { max-width: 640px; }
  .next h2 { color: #fff; }
  .next p { color: rgba(255,255,255,0.7); font-size: 1rem; line-height: 1.7; margin-bottom: 28px; }
  .next-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-solid { background: var(--red); color: #fff; text-decoration: none; padding: 13px 28px; border-radius: 10px; font-weight: 700; font-size: 0.92rem; transition: transform 0.2s, background 0.2s; }
  .btn-solid:hover { background: var(--red-dark); transform: translateY(-2px); }
  .btn-ghost { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,0.3); text-decoration: none; padding: 11px 26px; border-radius: 10px; font-weight: 700; font-size: 0.92rem; transition: border-color 0.2s; }
  .btn-ghost:hover { border-color: #fff; }

  @media (max-width: 900px) {
    .start-grid, .stroke-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .start-grid, .stroke-grid { grid-template-columns: 1fr; }
    .intro, .rules, .start, .strokes, .next { padding-left: 20px; padding-right: 20px; }
  }
</style>
