---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const programme = [
  {
    date: 'Tuesday 4th Nov',
    events: ['400m Freestyle'],
    pdf: 'https://torquayleander.co.uk/wp-content/uploads/2025/11/400-Free-Heat-Sheets-4th-Nov_.pdf',
  },
  {
    date: 'Monday 10th Nov',
    events: ['100m Individual Medley', '25m Backstroke', '200m Breaststroke', '50m Backstroke', '100m Freestyle'],
    pdf: 'https://torquayleander.co.uk/wp-content/uploads/2025/11/Heat-Sheets-Monday-10th-Nov-Sponsors.pdf',
  },
  {
    date: 'Sunday 16th Nov',
    events: ['25m Butterfly', '50m Freestyle', '100m Butterfly', '200m Backstroke', '25m Breaststroke', '50m Butterfly', '100m Breaststroke', '200m Freestyle'],
    pdf: 'https://torquayleander.co.uk/wp-content/uploads/2025/11/Heat-Sheets-Sunday-16th-Nov-Sponsors.pdf',
  },
  {
    date: 'Thursday 20th Nov',
    events: ['200m Individual Medley', '25m Freestyle', '50m Breaststroke', '100m Backstroke', '200m Butterfly'],
    pdf: 'https://torquayleander.co.uk/wp-content/uploads/2025/11/Thursday-20th-November-Heat-Sheets_.pdf',
  },
];

const ageGroups = ['7 years &amp; under', '8–9 years', '10–11 years', '12–13 years', '14–15 years', '16 years &amp; over'];
const longDistance = ['400m Individual Medley', '800m Freestyle', '1500m Freestyle', '200m Butterfly'];
---
<BaseLayout title="Club Championships — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <a href={`${base}/galas/`}>Galas &amp; Competitions</a>
      <span>›</span>
      <span>Club Championships</span>
    </div>
    <h1>Club Championships</h1>
    <p>Torquay Leander's internal championship meet — open to all club members and a great way to race in a friendly, familiar environment.</p>
  </div>
</section>

<section class="intro">
  <div class="inner intro-inner">
    <p class="label">About the Championships</p>
    <p class="intro-text">Each year Torquay Leander holds its Annual Club Championships as a <strong>licensed competition</strong>. This is great news for our swimmers: every time achieved is treated as official, and can be used for entry into other licensed meets and for Swim England (ASA) rankings. The licensed races take place across a series of evenings, with some longer-distance unlicensed races held at other times.</p>
    <p class="intro-text">All Torquay Leander swimmers are capable of entering a race or two. The championships are fun and a great way to get to know other swimmers in the club. <strong>Speak to your coach if you're unsure what to enter</strong> — and if it's your first gala, take a look at our competition guide.</p>
    <a class="guide-link" href={`${base}/galas/competition-guide/`}>
      Read the competition guide
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</section>

<section class="format">
  <div class="inner">
    <p class="label">Format &amp; Age Groups</p>
    <div class="format-grid">
      <div class="format-card">
        <h3>Age groups</h3>
        <p class="fc-sub">Age groups are based on the swimmer's age on 31st December.</p>
        <div class="age-chips">
          {ageGroups.map((a) => <span class="age-chip" set:html={a} />)}
        </div>
      </div>
      <div class="format-card">
        <h3>Longer-distance races</h3>
        <p class="fc-sub">Held as unlicensed events at separate times for swimmers aged 10 &amp; over.</p>
        <ul class="ld-list">
          {longDistance.map((e) => <li>{e}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="programme">
  <div class="inner">
    <p class="label">Latest Programme &amp; Heat Sheets</p>
    <h2>2025 Club Championships</h2>
    <p class="prog-text">Heat sheets from our most recent championships are below. Dates for the next championships are confirmed each autumn — keep an eye on our Facebook page for announcements.</p>

    <div class="prog-list">
      {programme.map((day) => (
        <div class="prog-day">
          <div class="prog-head">
            <span class="prog-date">{day.date}</span>
            <a class="prog-pdf" href={day.pdf} target="_blank" rel="noopener noreferrer">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
              Heat sheets
            </a>
          </div>
          <div class="prog-events">
            {day.events.map((e) => <span class="event-tag">{e}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="faq">
  <div class="inner">
    <p class="label">On the Day</p>
    <div class="faq-grid">
      <div class="faq-card">
        <span class="faq-icon">⏰</span>
        <h3>Arrive in good time</h3>
        <p>Please arrive approximately 15 minutes before the session warm-up time so swimmers are ready to go.</p>
      </div>
      <div class="faq-card">
        <span class="faq-icon">🍫</span>
        <h3>Tuck shop</h3>
        <p>A tuck shop runs during all sessions, selling snacks, juice and water.</p>
      </div>
      <div class="faq-card">
        <span class="faq-icon">🎟️</span>
        <h3>50/50 raffle</h3>
        <p>We run a 50/50 raffle — half the proceeds go into the prize pot, and half towards the cost of running the championships.</p>
      </div>
      <div class="faq-card">
        <span class="faq-icon">📖</span>
        <h3>First gala?</h3>
        <p>If this is your first gala, our <a href={`${base}/galas/competition-guide/`}>competition guide</a> walks you through what to expect.</p>
      </div>
    </div>
  </div>
</section>

<section class="extras">
  <div class="inner extras-grid">
    <div class="extra-card">
      <h3>Devon Championship qualifying times</h3>
      <p>The Devon Championship qualifying times are set annually by Devon County ASA. These "County Times" are required for entry into the Devon County Championships, typically held at the Plymouth Life Centre.</p>
      <a class="extra-link" href="https://torquayleander.co.uk/wp-content/uploads/2025/11/2026-Devon-Championship-Qualifying-Times-V1.pdf" target="_blank" rel="noopener noreferrer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
        2026 Devon qualifying times
      </a>
    </div>
    <div class="extra-card highlight">
      <span class="extra-emoji">🏆</span>
      <h3>Awards Night</h3>
      <p>Each January we hold our annual awards night — great fun with food and a disco, and a chance to celebrate all of our fantastic young swimmers. Trophies and medals won at the club championships are awarded on the evening.</p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; flex-wrap: wrap; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 600px; line-height: 1.7; }

  .inner { max-width: 1100px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }

  .intro { background: #fff; padding: 72px 5vw 56px; }
  .intro-inner { max-width: 820px; }
  .intro-text { color: var(--muted); font-size: 1.02rem; line-height: 1.85; margin-bottom: 18px; }
  .intro-text strong { color: var(--text); }
  .guide-link { display: inline-flex; align-items: center; gap: 8px; color: var(--red); font-weight: 700; font-size: 0.92rem; text-decoration: none; margin-top: 6px; }
  .guide-link:hover { text-decoration: underline; }

  .format { background: #f8fafc; padding: 64px 5vw; }
  .format-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .format-card { background: #fff; border: 1.5px solid var(--border); border-radius: 16px; padding: 28px 26px; }
  .format-card h3 { font-size: 1.05rem; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .fc-sub { color: var(--muted); font-size: 0.86rem; line-height: 1.6; margin-bottom: 18px; }
  .age-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .age-chip { background: var(--red-light); color: var(--red-dark); border-radius: 999px; padding: 7px 14px; font-size: 0.82rem; font-weight: 700; }
  .ld-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .ld-list li { padding-left: 20px; position: relative; color: var(--text); font-size: 0.9rem; font-weight: 600; }
  .ld-list li::before { content: ''; position: absolute; left: 0; top: 7px; width: 8px; height: 8px; border-radius: 50%; background: var(--red); }

  .programme { background: #fff; padding: 64px 5vw; }
  .programme h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 12px; }
  .prog-text { color: var(--muted); font-size: 0.97rem; line-height: 1.75; max-width: 760px; margin-bottom: 32px; }
  .prog-list { display: flex; flex-direction: column; gap: 16px; }
  .prog-day { border: 1.5px solid var(--border); border-radius: 14px; padding: 22px 24px; }
  .prog-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
  .prog-date { font-size: 1.05rem; font-weight: 800; color: var(--text); }
  .prog-pdf { display: inline-flex; align-items: center; gap: 7px; background: var(--red-light); color: var(--red); border-radius: 8px; padding: 8px 14px; font-size: 0.8rem; font-weight: 700; text-decoration: none; transition: background 0.2s, color 0.2s; }
  .prog-pdf:hover { background: var(--red); color: #fff; }
  .prog-events { display: flex; flex-wrap: wrap; gap: 8px; }
  .event-tag { background: #f1f5f9; border: 1px solid var(--border); border-radius: 8px; padding: 6px 12px; font-size: 0.8rem; font-weight: 600; color: var(--text); }

  .faq { background: #f8fafc; padding: 64px 5vw; }
  .faq-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .faq-card { background: #fff; border: 1.5px solid var(--border); border-radius: 14px; padding: 24px 22px; }
  .faq-icon { font-size: 1.6rem; display: block; margin-bottom: 12px; }
  .faq-card h3 { font-size: 0.95rem; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .faq-card p { color: var(--muted); font-size: 0.83rem; line-height: 1.6; margin: 0; }
  .faq-card a { color: var(--red); font-weight: 700; text-decoration: none; }
  .faq-card a:hover { text-decoration: underline; }

  .extras { background: #fff; padding: 64px 5vw 80px; }
  .extras-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .extra-card { border: 1.5px solid var(--border); border-radius: 16px; padding: 30px 28px; }
  .extra-card h3 { font-size: 1.1rem; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .extra-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.7; margin-bottom: 16px; }
  .extra-link { display: inline-flex; align-items: center; gap: 7px; color: var(--red); font-weight: 700; font-size: 0.85rem; text-decoration: none; }
  .extra-link:hover { text-decoration: underline; }
  .extra-card.highlight { background: linear-gradient(135deg, var(--red-dark), var(--red)); border-color: transparent; }
  .extra-card.highlight h3, .extra-card.highlight p { color: #fff; }
  .extra-card.highlight p { color: rgba(255,255,255,0.9); margin-bottom: 0; }
  .extra-emoji { font-size: 2rem; display: block; margin-bottom: 10px; }

  @media (max-width: 900px) {
    .faq-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 700px) {
    .format-grid, .extras-grid { grid-template-columns: 1fr; }
    .intro, .format, .programme, .faq, .extras { padding-left: 20px; padding-right: 20px; }
  }
  @media (max-width: 480px) {
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>
