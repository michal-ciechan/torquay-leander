---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const expect = [
  { icon: '🏊', title: 'A familiar pool', text: 'The gala is held in-house at our own pool, so there\'s no travelling to an unfamiliar venue — just a friendly, supportive environment.' },
  { icon: '🎀', title: 'Ribbons for taking part', text: 'It\'s about the experience, not just the result. Swimmers are recognised for getting up and racing, whatever their finishing position.' },
  { icon: '👏', title: 'A supportive crowd', text: 'Teammates, coaches and families cheer every swimmer on. It\'s a relaxed, encouraging atmosphere designed to build confidence.' },
  { icon: '⏱️', title: 'A first official-style race', text: 'Swimmers experience warming up, lining up behind the blocks, and racing to a whistle start — perfect preparation for bigger meets.' },
];
---
<BaseLayout title="Ribbon Gala — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <a href={`${base}/galas/`}>Galas &amp; Competitions</a>
      <span>›</span>
      <span>Ribbon Gala</span>
    </div>
    <h1>Ribbon Gala</h1>
    <p>A fun introduction to competition for newer swimmers — racing in a safe, familiar environment.</p>
  </div>
</section>

<section class="intro">
  <div class="inner intro-inner">
    <p class="label">About the Ribbon Gala</p>
    <p class="intro-text">Every year Torquay Leander holds in-house ribbon galas where swimmers can get a taste for competing in a safe, familiar environment. The ribbon gala is often a swimmer's very first race — a relaxed, encouraging event held at our own pool, designed to introduce the fun of competition without the pressure of a full open meet.</p>
    <p class="intro-text">It's the perfect first step on the competitive pathway. Swimmers learn what it feels like to warm up, line up and race, building the confidence they need to go on and represent the club at local, county and regional galas.</p>
  </div>
</section>

<section class="expect">
  <div class="inner">
    <p class="label">What to Expect</p>
    <div class="expect-grid">
      {expect.map((e) => (
        <div class="expect-card">
          <span class="expect-icon">{e.icon}</span>
          <h3>{e.title}</h3>
          <p>{e.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="enter">
  <div class="inner enter-inner">
    <div class="enter-text">
      <p class="label">How to Take Part</p>
      <h2>Ready to race?</h2>
      <p>Ribbon galas are open to our newer swimmers and dates are announced through the club during the year. If your swimmer is ready to give racing a go, have a word with their coach — they'll let you know when the next gala is and which events to enter.</p>
      <p class="muted">First time competing? Our competition guide explains exactly what happens on the day, from the warm-up to the whistle.</p>
      <div class="enter-btns">
        <a class="btn-solid" href={`${base}/galas/competition-guide/`}>Read the competition guide</a>
        <a class="btn-ghost" href={`${base}/galas/`}>Back to Galas</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; flex-wrap: wrap; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 580px; line-height: 1.7; }

  .inner { max-width: 1100px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
  h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }

  .intro { background: #fff; padding: 72px 5vw 56px; }
  .intro-inner { max-width: 820px; }
  .intro-text { color: var(--muted); font-size: 1.02rem; line-height: 1.85; margin-bottom: 18px; }

  .expect { background: #f8fafc; padding: 64px 5vw; }
  .expect-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .expect-card { background: #fff; border: 1.5px solid var(--border); border-radius: 16px; padding: 26px 22px; transition: border-color 0.2s, transform 0.2s; }
  .expect-card:hover { border-color: var(--red); transform: translateY(-3px); }
  .expect-icon { font-size: 1.8rem; display: block; margin-bottom: 12px; }
  .expect-card h3 { font-size: 0.95rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .expect-card p { color: var(--muted); font-size: 0.84rem; line-height: 1.65; margin: 0; }

  .enter { background: #fff; padding: 24px 5vw 80px; }
  .enter-inner { max-width: 820px; }
  .enter-text p { color: var(--muted); font-size: 1rem; line-height: 1.8; margin-bottom: 16px; }
  .enter-text p.muted { font-size: 0.92rem; }
  .enter-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 24px; }
  .btn-solid { background: var(--red); color: #fff; text-decoration: none; padding: 13px 28px; border-radius: 10px; font-weight: 700; font-size: 0.92rem; transition: transform 0.2s, background 0.2s; }
  .btn-solid:hover { background: var(--red-dark); transform: translateY(-2px); }
  .btn-ghost { background: transparent; color: var(--text); border: 2px solid var(--border); text-decoration: none; padding: 11px 26px; border-radius: 10px; font-weight: 700; font-size: 0.92rem; transition: border-color 0.2s; }
  .btn-ghost:hover { border-color: var(--red); }

  @media (max-width: 900px) {
    .expect-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .expect-grid { grid-template-columns: 1fr; }
    .intro, .expect, .enter { padding-left: 20px; padding-right: 20px; }
  }
</style>
