---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Safeguarding & Welfare — Torquay Leander">

<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <span>Safeguarding &amp; Welfare</span>
    </div>
    <h1>Safeguarding &amp; Welfare</h1>
    <p>Creating a safe, supportive, and inclusive environment for all children and young people is a priority within aquatics.</p>
  </div>
</section>

<section class="swimline-section">
  <div class="inner">
    <div class="section-intro-block">
      <p class="label">Swimline – Confidential Support Service</p>
      <p class="lead">Swim England works in partnership with the NSPCC to provide Swimline, a confidential freephone helpline for anyone involved in aquatic sports.</p>
    </div>

    <div class="swimline-grid">
      <div class="swimline-col">
        <h3>Who Can Use Swimline</h3>
        <p class="swimline-text">Swimline is available to both adults and children who may be worried about:</p>
        <ul class="concern-list">
          <li>
            <span class="concern-dot"></span>
            Bullying
          </li>
          <li>
            <span class="concern-dot"></span>
            Neglect
          </li>
          <li>
            <span class="concern-dot"></span>
            Abuse
          </li>
          <li>
            <span class="concern-dot"></span>
            Inappropriate behaviour
          </li>
          <li>
            <span class="concern-dot"></span>
            Feeling unsafe or frightened
          </li>
          <li>
            <span class="concern-dot"></span>
            Any safeguarding concern involving a child or young person
          </li>
        </ul>
        <p class="swimline-text" style="margin-top: 18px;">Even if you are unsure whether your concern is serious, you are encouraged to seek advice.</p>
      </div>

      <div class="swimline-col">
        <h3>How Swimline Works</h3>
        <p class="swimline-text">When you contact Swimline, you will reach a confidential answerphone service. You can leave:</p>
        <ul class="concern-list" style="margin-bottom: 18px;">
          <li><span class="concern-dot"></span>Your name</li>
          <li><span class="concern-dot"></span>Contact details</li>
          <li><span class="concern-dot"></span>Brief information about your concern (optional)</li>
        </ul>
        <p class="swimline-text">A member of the Swim England Safeguarding Team or a trained Swimline volunteer will return your call to discuss the concern and help decide on the most appropriate course of action.</p>
        <div class="response-cards">
          <div class="response-card">
            <strong>Response times</strong>
            <p>Messages are normally returned on the next working day. Messages left after 3pm on Fridays or over weekends will be returned on Monday.</p>
          </div>
          <div class="response-card response-card--urgent">
            <strong>Urgent concerns</strong>
            <p>If urgent support is needed, callers can choose to be transferred directly to the NSPCC for immediate advice from a trained counsellor.</p>
          </div>
        </div>
        <div class="swimline-note">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>Calls to Swimline are free of charge. Calls made from landlines will not appear on itemised bills, although mobile phone providers may record outgoing calls on billing statements. Where safeguarding concerns are identified, Swim England will always take appropriate action to help protect children and young people.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="welfare-section">
  <div class="inner">
    <p class="label">Club Welfare Officers</p>
    <p class="lead">Our welfare officers are trained to handle any safeguarding concerns within the club. Please contact them directly if you have a concern.</p>
    <div class="officer-grid">
      <div class="officer-card">
        <div class="officer-avatar">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="officer-body">
          <span class="officer-role">Club Welfare Officer</span>
          <h3>Rosie Johnston</h3>
          <a class="officer-contact" href="tel:07813645077">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.86a16 16 0 0 0 6.07 6.07l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            07813 645077
          </a>
          <a class="officer-contact" href="mailto:wo.torquayleander@outlook.com">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            wo.torquayleander@outlook.com
          </a>
        </div>
      </div>

      <div class="officer-card">
        <div class="officer-avatar">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="officer-body">
          <span class="officer-role">Club Deputy Welfare Officer</span>
          <h3>Roger Downing</h3>
          <a class="officer-contact" href="tel:07756263710">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.86a16 16 0 0 0 6.07 6.07l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            07756 263710
          </a>
          <a class="officer-contact" href="mailto:wo.torquayleander@outlook.com">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            wo.torquayleander@outlook.com
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="helplines-section">
  <div class="inner">
    <p class="label">Additional Support &amp; Helplines</p>
    <p class="lead">If you or someone you know needs support, these national organisations provide confidential help around the clock.</p>
    <div class="table-wrap">
      <table class="helplines-table">
        <thead>
          <tr>
            <th>Organisation</th>
            <th>Phone</th>
            <th>Website</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Childline</strong></td>
            <td><a href="tel:08001111">0800 1111</a></td>
            <td><a href="https://www.childline.org.uk" target="_blank" rel="noopener">childline.org.uk</a></td>
          </tr>
          <tr>
            <td><strong>NSPCC</strong></td>
            <td><a href="tel:08088005000">0808 800 5000</a></td>
            <td><a href="https://www.nspcc.org.uk" target="_blank" rel="noopener">nspcc.org.uk</a></td>
          </tr>
          <tr>
            <td><strong>Young Minds</strong></td>
            <td><a href="tel:08088025544">0808 802 5544</a></td>
            <td><a href="https://www.youngminds.org.uk" target="_blank" rel="noopener">youngminds.org.uk</a></td>
          </tr>
          <tr>
            <td><strong>Mind</strong></td>
            <td><a href="tel:03001233393">0300 123 3393</a></td>
            <td><a href="https://www.mind.org.uk" target="_blank" rel="noopener">mind.org.uk</a></td>
          </tr>
          <tr>
            <td><strong>Samaritans</strong></td>
            <td><a href="tel:116123">116 123</a></td>
            <td><a href="https://www.samaritans.org" target="_blank" rel="noopener">samaritans.org</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="resources-section">
  <div class="inner">
    <p class="label">Useful Resources</p>
    <a class="resource-card" href="https://www.swimming.org/swimengland/wavepower-child-safeguarding-for-clubs/" target="_blank" rel="noopener">
      <div class="resource-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </div>
      <div class="resource-body">
        <strong>Wavepower</strong>
        <span>Swim England Safeguarding Policy</span>
      </div>
      <span class="resource-go">View →</span>
    </a>
  </div>
</section>

<section class="local-section">
  <div class="inner">
    <p class="label">Local Safeguarding Contact Information</p>
    <p class="lead">For local safeguarding concerns in Devon and Torbay, contact the Multi-Agency Safeguarding Hub (MASH) directly.</p>

    <div class="local-grid">
      <div class="local-group">
        <h3>Safeguarding Adults</h3>
        <div class="local-card">
          <span class="local-area">Devon</span>
          <div class="local-contacts">
            <a href="tel:03451551007">0345 155 1007</a>
            <a href="mailto:mashsecure@devon.gov.uk">mashsecure@devon.gov.uk</a>
          </div>
        </div>
        <div class="local-card">
          <span class="local-area">Torbay</span>
          <div class="local-contacts">
            <a href="tel:01803219700">01803 219700</a>
            <a href="mailto:mash@torbay.gov.uk">mash@torbay.gov.uk</a>
          </div>
        </div>
      </div>

      <div class="local-group">
        <h3>Safeguarding Children</h3>
        <div class="local-card">
          <span class="local-area">Devon</span>
          <div class="local-contacts">
            <a href="tel:03451551071">0345 155 1071</a>
            <a href="mailto:mashsecure@devon.cgsx.gov.uk">mashsecure@devon.cgsx.gov.uk</a>
          </div>
        </div>
        <div class="local-card">
          <span class="local-area">Torbay</span>
          <div class="local-contacts">
            <a href="tel:01803208100">01803 208100</a>
            <a href="mailto:torbay.safeguardinghub@torbay.gcsx.co.uk">torbay.safeguardinghub@torbay.gcsx.co.uk</a>
          </div>
        </div>
      </div>

      <div class="local-group local-group--ooh">
        <h3>Out of Hours</h3>
        <div class="local-card local-card--dark">
          <span class="local-area">Devon</span>
          <div class="local-contacts">
            <a href="tel:03456000388">0345 6000 388</a>
          </div>
        </div>
        <div class="local-card local-card--dark">
          <span class="local-area">Torbay</span>
          <div class="local-contacts">
            <a href="tel:03004564876">0300 456 4876</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; }
  .crumb a { color: var(--red); text-decoration: none; }
  .crumb span { opacity: 0.5; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 600px; line-height: 1.7; }

  .inner { max-width: 1200px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .lead { color: var(--muted); font-size: 1rem; line-height: 1.8; max-width: 700px; }

  .swimline-section { background: #fff; padding: 80px 5vw; }
  .section-intro-block { margin-bottom: 48px; }
  .section-intro-block h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }
  .swimline-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .swimline-col h3 { font-size: 1rem; font-weight: 700; margin-bottom: 16px; color: var(--text); }
  .concern-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .concern-list li { display: flex; align-items: center; gap: 12px; font-size: 0.9rem; color: var(--text); }
  .concern-dot { flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%; background: var(--red); }
  .swimline-text { color: var(--muted); font-size: 0.9rem; line-height: 1.7; margin-bottom: 20px; }
  .response-cards { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
  .response-card { background: #f8fafc; border: 1.5px solid var(--border); border-radius: 12px; padding: 16px 18px; }
  .response-card strong { display: block; font-size: 0.88rem; font-weight: 700; margin-bottom: 4px; }
  .response-card p { color: var(--muted); font-size: 0.82rem; line-height: 1.6; margin: 0; }
  .response-card--urgent { border-color: #fecaca; background: var(--red-light); }
  .response-card--urgent strong { color: var(--red-dark); }
  .swimline-note {
    background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 10px;
    padding: 12px 16px; display: flex; gap: 10px; align-items: flex-start;
    color: #0369a1; font-size: 0.82rem; line-height: 1.6;
  }
  .swimline-note svg { flex-shrink: 0; margin-top: 1px; color: #0369a1; }

  .welfare-section { background: var(--red-light); padding: 80px 5vw; }
  .welfare-section h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }
  .officer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 40px; }
  .officer-card {
    background: #fff; border: 1.5px solid var(--border); border-radius: 16px;
    padding: 28px 24px; display: flex; gap: 20px; align-items: flex-start;
    transition: all 0.2s;
  }
  .officer-card:hover { border-color: var(--red); box-shadow: 0 8px 30px rgba(220,38,38,0.1); }
  .officer-avatar {
    flex-shrink: 0; width: 56px; height: 56px;
    background: linear-gradient(135deg, var(--red-dark), var(--red));
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    color: #fff;
  }
  .officer-role { display: block; font-size: 0.72rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--red); margin-bottom: 4px; }
  .officer-body h3 { font-size: 1.05rem; font-weight: 800; margin-bottom: 12px; }
  .officer-contact {
    display: flex; align-items: center; gap: 8px;
    color: var(--muted); text-decoration: none; font-size: 0.85rem;
    margin-bottom: 8px; transition: color 0.2s;
  }
  .officer-contact:hover { color: var(--red); }
  .officer-contact svg { flex-shrink: 0; color: var(--red); }

  .helplines-section { background: #fff; padding: 80px 5vw; }
  .helplines-section h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }
  .table-wrap { margin-top: 40px; overflow-x: auto; border-radius: 14px; border: 1.5px solid var(--border); }
  .helplines-table { width: 100%; border-collapse: collapse; }
  .helplines-table thead { background: var(--black); }
  .helplines-table th { color: rgba(255,255,255,0.75); font-size: 0.75rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 14px 20px; text-align: left; }
  .helplines-table td { padding: 14px 20px; font-size: 0.88rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
  .helplines-table tbody tr:last-child td { border-bottom: none; }
  .helplines-table tbody tr:hover td { background: var(--red-light); }
  .helplines-table td strong { font-weight: 700; color: var(--text); }
  .helplines-table td a { color: var(--red); text-decoration: none; font-weight: 600; }
  .helplines-table td a:hover { text-decoration: underline; }

  .resources-section { background: var(--red-light); padding: 56px 5vw; }
  .resource-card {
    display: flex; align-items: center; gap: 18px; max-width: 520px;
    background: #fff; border: 1.5px solid var(--border); border-radius: 14px;
    padding: 22px 24px; margin-top: 24px; text-decoration: none; color: inherit;
    transition: all 0.2s;
  }
  .resource-card:hover { border-color: var(--red); box-shadow: 0 10px 30px rgba(220,38,38,0.1); transform: translateY(-2px); }
  .resource-icon {
    flex-shrink: 0; width: 48px; height: 48px; border-radius: 12px;
    background: var(--red-light); color: var(--red);
    display: flex; align-items: center; justify-content: center;
  }
  .resource-body { flex: 1; }
  .resource-body strong { display: block; font-size: 1rem; font-weight: 800; color: var(--text); }
  .resource-body span { font-size: 0.85rem; color: var(--muted); }
  .resource-go { font-size: 0.85rem; font-weight: 700; color: var(--red); white-space: nowrap; }

  .local-section { background: #f8fafc; padding: 80px 5vw; }
  .local-section h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 14px; }
  .local-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 40px; }
  .local-group h3 { font-size: 0.88rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text); margin-bottom: 14px; }
  .local-card {
    background: #fff; border: 1.5px solid var(--border); border-radius: 12px;
    padding: 16px 18px; margin-bottom: 10px; display: flex; gap: 14px; align-items: flex-start;
  }
  .local-card--dark { background: var(--black); border-color: var(--black); }
  .local-area {
    flex-shrink: 0; font-size: 0.7rem; font-weight: 800; letter-spacing: 1px;
    text-transform: uppercase; color: var(--red); background: var(--red-light);
    padding: 3px 8px; border-radius: 6px; margin-top: 2px;
  }
  .local-card--dark .local-area { background: rgba(220,38,38,0.15); color: #f87171; }
  .local-contacts { display: flex; flex-direction: column; gap: 5px; }
  .local-contacts a { color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: color 0.2s; word-break: break-all; }
  .local-contacts a:hover { color: var(--red); }
  .local-card--dark .local-contacts a { color: rgba(255,255,255,0.7); }
  .local-card--dark .local-contacts a:hover { color: #f87171; }
  .local-group--ooh h3 { color: var(--muted); }

  @media (max-width: 900px) {
    .swimline-grid { grid-template-columns: 1fr; gap: 32px; }
    .officer-grid { grid-template-columns: 1fr; }
    .local-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .local-grid { grid-template-columns: 1fr; }
    .swimline-section, .welfare-section, .helplines-section, .local-section { padding: 48px 20px; }
  }
</style>
