---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Gallery — Torquay Leander Swimming Club">

<div class="page-hero">
  <h1>Photo Gallery</h1>
  <p>Moments from training, competition, and club life — browse by event below.</p>
</div>

<!-- EVENT TABS -->
<div class="event-tabs">
  <button class="tab active" onclick="showTab(0)">All Events</button>
  <button class="tab" onclick="showTab(1)">Competition Day</button>
  <button class="tab" onclick="showTab(2)">Training Sessions</button>
  <button class="tab" onclick="showTab(3)">Club Life &amp; Social</button>
  <button class="tab" onclick="showTab(4)">Junior Academy</button>
</div>

<!-- ALL EVENTS OVERVIEW -->
<section class="gallery-section active" id="tab-0">
  <div class="events-overview">
    <div class="events-grid">
      <a class="event-card" onclick="showTab(1); return false;" href="#">
        <div class="event-card-img">
          <img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_7899-400x284.jpg" alt="Competition" />
          <span class="event-count">6 photos</span>
        </div>
        <div class="event-card-body">
          <p class="tag">Event Gallery</p>
          <h3>Competition Day</h3>
          <p>Race days, county championships and club meets.</p>
        </div>
      </a>
      <a class="event-card" onclick="showTab(2); return false;" href="#">
        <div class="event-card-img">
          <img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_2568-400x284.jpg" alt="Training" />
          <span class="event-count">7 photos</span>
        </div>
        <div class="event-card-body">
          <p class="tag">Event Gallery</p>
          <h3>Training Sessions</h3>
          <p>Day-to-day practice, drills and technique work in the pool.</p>
        </div>
      </a>
      <a class="event-card" onclick="showTab(3); return false;" href="#">
        <div class="event-card-img">
          <img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_6883-400x284.jpeg" alt="Club Life" />
          <span class="event-count">7 photos</span>
        </div>
        <div class="event-card-body">
          <p class="tag">Event Gallery</p>
          <h3>Club Life &amp; Social</h3>
          <p>Awards evenings, end-of-season events and team get-togethers.</p>
        </div>
      </a>
      <a class="event-card" onclick="showTab(4); return false;" href="#">
        <div class="event-card-img">
          <img src="https://torquayleander.co.uk/wp-content/uploads/2021/08/DSC_2453-400x284.jpg" alt="Juniors" />
          <span class="event-count">7 photos</span>
        </div>
        <div class="event-card-body">
          <p class="tag">Event Gallery</p>
          <h3>Junior Academy</h3>
          <p>Our youngest swimmers building skills and confidence.</p>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- COMPETITION DAY -->
