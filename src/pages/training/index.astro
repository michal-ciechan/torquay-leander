---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const squadSessions = [
  {
    name: 'Development Squad',
    desc: 'Our improving swimmers in the Development squad are working on reinforcing their basic skills, stroke technique and improving their dives and turns. An introduction to competitive swimming as their stamina improves, includes in-house ribbon galas and club championships before attending galas further afield.',
    times: [
      { day: 'Monday', time: '6pm – 7pm' },
      { day: 'Thursday', time: '6pm – 7pm' },
      { day: 'Friday', time: '6pm – 7pm' },
      { day: 'Saturday', time: '9am – 10am' },
    ],
    accent: 'dev',
  },
  {
    name: 'Junior Squad',
    desc: 'Swimmers continue to build their stamina through tougher training sessions. Race skills are developed such as starts, turns and finishes for each stroke and Individual Medley. Swimmers can enjoy competing in local competitions, team gala events and Devon Developments.',
    times: [
      { day: 'Monday', time: '7pm – 8pm' },
      { day: 'Thursday', time: '7pm – 8pm' },
      { day: 'Friday', time: '6pm – 7pm' },
      { day: 'Saturday', time: '9am – 10am' },
    ],
    accent: 'junior',
  },
  {
    name: 'Senior Squad',
    desc: 'Senior swimmers train with a commitment to participate in County competitions, team gala events and open meets. Those who swim for fitness only, are also encouraged to support the club in team galas.',
    times: [
      { day: 'Monday', time: '8pm – 9pm' },
      { day: 'Tuesday', time: '7pm – 9pm' },
      { day: 'Wednesday', time: '8pm – 9pm' },
      { day: 'Thursday', time: '8pm – 9pm' },
      { day: 'Friday', time: '6pm – 7pm' },
      { day: 'Saturday', time: '9am – 10am' },
    ],
    accent: 'senior',
  },
];

const coaches = [
  { name: 'Neil', role: 'Head Coach', img: 'https://torquayleander.co.uk/wp-content/uploads/2021/08/Neil-e1628767191779-400x516.jpg' },
  { name: 'Lisa', role: 'Coach', img: 'https://torquayleander.co.uk/wp-content/uploads/2023/07/lisa-400x516.jpg' },
  { name: 'Gerry', role: 'Coach', img: 'https://torquayleander.co.uk/wp-content/uploads/2021/07/Coach-2-2000-x-1600-e1628661652650-400x516.jpg' },
  { name: 'Jon', role: 'Coach', img: 'https://torquayleander.co.uk/wp-content/uploads/2025/01/IMG_0603-400x516.jpg' },
  { name: 'Matt', role: 'Coach', img: 'https://torquayleander.co.uk/wp-content/uploads/2021/07/Poolside-Helper-1-2000-x-1600-e1628763126628-400x516.jpg' },
  { name: 'Becky', role: 'Coach', img: 'https://torquayleander.co.uk/wp-content/uploads/2025/01/IMG_6420-scaled-e1738265017605-400x516.jpg' },
  { name: 'Giles', role: 'Poolside Helper', img: 'https://torquayleander.co.uk/wp-content/uploads/2025/01/IMG_6422-scaled-e1738264896412-400x516.jpg' },
  { name: 'Katie', role: 'Poolside Helper', img: 'https://torquayleander.co.uk/wp-content/uploads/2025/01/IMG_6424-scaled-e1738264824150-400x516.jpg' },
];
---
<BaseLayout title="Training — Torquay Leander Swimming Club">

<!-- HERO -->
<section class="page-hero">
  <div class="hero-inner">
    <div class="crumb">
      <a href={`${base}/`}>Home</a>
      <span>›</span>
      <span>Training</span>
    </div>
    <h1>Training at Torquay Leander</h1>
    <p>Professional qualified coaching for every training session, with a specific annual training plan built around our gala program.</p>
    <div class="hero-pills">
      <span class="pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Professional qualified coaching</span>
      <span class="pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> No minimum training hours</span>
      <span class="pill"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Free trial session</span>
    </div>
  </div>
</section>

<!-- SUB-PAGES -->
<section class="sub-nav">
  <div class="inner">
    <div class="sub-cards">
      <a class="sub-card" href="#timetable">
        <span class="sub-icon">📅</span>
        <strong>Training Timetable</strong>
        <span>Weekly session times for every squad</span>
      </a>
      <a class="sub-card" href="#coaches">
        <span class="sub-icon">🏊</span>
        <strong>Our Coaches</strong>
        <span>Meet our volunteer coaching team</span>
      </a>
      <a class="sub-card" href={`${base}/training/equipment/`}>
        <span class="sub-icon">🎒</span>
        <strong>Training Equipment</strong>
        <span>The kit every swimmer needs</span>
      </a>
      <a class="sub-card" href={`${base}/training/learn-to-swim/`}>
        <span class="sub-icon">🌊</span>
        <strong>Learn to Swim</strong>
        <span>The pathway into our squads</span>
      </a>
    </div>
  </div>
</section>

<!-- TIMETABLE -->
<section class="sessions" id="timetable">
  <div class="inner">
    <p class="label">Training Timetable</p>
    <p class="lead">All swimmers have an allocated swimming day and time to ensure that swimming sessions do not get congested. Please note that movement between sessions is at the discretion of the Coach and must be discussed.</p>

    <div class="sessions-note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      All swimmers should be poolside 5 minutes before their session starts in order to start warming up.
    </div>

    <div class="squad-times-grid">
      {squadSessions.map((s) => (
        <div class="squad-times-card">
          <div class={`squad-times-head ${s.accent}`}>
            <h3>{s.name}</h3>
          </div>
          <p class="squad-times-desc">{s.desc}</p>
          <table class="times-table">
            <thead>
              <tr><th>Day</th><th>Time</th></tr>
            </thead>
            <tbody>
              {s.times.map((t) => (
                <tr><td>{t.day}</td><td>{t.time}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>

    <div class="squads-xlink">
      <p>Want to know more about our squad structure and progression pathway?</p>
      <a href={`${base}/about/squads/`}>Our Squads →</a>
    </div>
  </div>
</section>

<!-- COACHES -->
<section class="coaches" id="coaches">
  <div class="inner">
    <p class="label">Our Coaches</p>
    <p class="lead">All of our coaches are volunteers who give up their own time to support, encourage, and develop every swimmer in the club. They are not paid for the countless hours they dedicate poolside, at competitions, and behind the scenes — they do it because they genuinely care about the swimmers and want to help each individual achieve their potential.</p>
    <p class="lead" style="margin-top:16px;">Our coaches are passionate about creating a positive environment where swimmers can learn, improve, build confidence, and enjoy the sport. Their commitment goes far beyond teaching technique; they provide encouragement, guidance, and support to help swimmers grow both in and out of the pool.</p>
    <p class="lead" style="margin-top:16px;">Quite simply, if they did not care, they would not continue to give their personal time so generously. We ask that all members, swimmers, and parents show our coaching team the same respect, support, and appreciation that they consistently show to our swimmers every day.</p>

    <div class="coaches-grid">
      {coaches.map((c) => (
        <div class="coach-card">
          <div class="coach-photo">
            <img src={c.img} alt={c.name} loading="lazy" />
          </div>
          <h3>{c.name}</h3>
          <p class="coach-role">{c.role}</p>
        </div>
      ))}
    </div>

    <p class="volunteer-note">Our club also relies on volunteers who do many different roles on the committee and organising events for the club. If you are interested in helping us in any shape or form, please do get in touch — there is something for everyone.</p>
  </div>
</section>

<!-- CTA -->
<section class="page-cta">
  <h2>Ready to Start Training?</h2>
  <p>Your first session is completely free. Come and meet the coaches, see the pool, and find out which squad is the right fit for you.</p>
  <a class="btn-white" href={`${base}/about/join/`}>Book a Free Trial</a>
</section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--black); padding: 64px 5vw 56px;
    position: relative; overflow: hidden;
  }
  .page-hero::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
    background: #fff; clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; }
  .crumb { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-bottom: 18px; }
  .crumb a { color: var(--red); text-decoration: none; }
  .page-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; }
  .page-hero p { color: rgba(255,255,255,0.65); font-size: 1rem; max-width: 580px; line-height: 1.7; margin-bottom: 32px; }
  .hero-pills { display: flex; gap: 10px; flex-wrap: wrap; }
  .pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.7); padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
  .pill svg { flex-shrink: 0; }

  .inner { max-width: 1200px; margin: 0 auto; }
  .label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .lead { color: var(--muted); font-size: 1rem; line-height: 1.8; max-width: 760px; }

  /* SUB-PAGE CARDS */
  .sub-nav { background: #fff; padding: 48px 5vw; }
  .sub-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .sub-card {
    display: flex; flex-direction: column; align-items: flex-start; gap: 6px;
    border: 1.5px solid var(--border); border-radius: 14px; padding: 22px 20px;
    text-decoration: none; color: inherit; transition: all 0.2s;
  }
  .sub-card:hover { border-color: var(--red); box-shadow: 0 8px 28px rgba(220,38,38,0.1); transform: translateY(-3px); }
  .sub-icon { font-size: 1.6rem; margin-bottom: 4px; }
  .sub-card strong { font-size: 0.95rem; font-weight: 800; color: var(--text); }
  .sub-card span { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

  /* TIMETABLE */
  .sessions { background: #f8fafc; }
  .sessions-note {
    background: var(--red-light); border: 1.5px solid #fecaca; border-radius: 12px;
    padding: 14px 18px; color: var(--red-dark); font-size: 0.85rem; line-height: 1.6;
    margin: 24px 0 36px; display: flex; gap: 10px; align-items: flex-start; max-width: 640px;
  }
  .sessions-note svg { flex-shrink: 0; margin-top: 2px; }

  .squad-times-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .squad-times-card { background: #fff; border: 1.5px solid var(--border); border-radius: 18px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.25s; }
  .squad-times-card:hover { transform: translateY(-4px); box-shadow: 0 16px 50px rgba(0,0,0,0.08); }
  .squad-times-head { padding: 22px 26px; }
  .squad-times-head.dev { background: linear-gradient(135deg, #0f766e, #0d9488); }
  .squad-times-head.junior { background: linear-gradient(135deg, #4338ca, #6366f1); }
  .squad-times-head.senior { background: linear-gradient(135deg, var(--red-dark), var(--red)); }
  .squad-times-head h3 { font-size: 1.2rem; font-weight: 900; color: #fff; letter-spacing: -0.5px; margin: 0; }
  .squad-times-desc { color: var(--muted); font-size: 0.86rem; line-height: 1.7; padding: 20px 26px 16px; margin: 0; flex: 1; }
  .times-table { width: 100%; border-collapse: collapse; }
  .times-table th {
    background: #f1f5f9; color: var(--muted); font-size: 0.72rem; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase; padding: 10px 26px; text-align: left;
  }
  .times-table td { padding: 11px 26px; font-size: 0.88rem; border-top: 1px solid var(--border); }
  .times-table td:first-child { font-weight: 700; color: var(--text); }
  .times-table td:last-child { color: var(--muted); }

  .squads-xlink {
    margin-top: 36px; background: var(--black); border-radius: 16px;
    padding: 24px 30px; display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap;
  }
  .squads-xlink p { color: rgba(255,255,255,0.8); font-size: 0.95rem; font-weight: 600; margin: 0; }
  .squads-xlink a {
    background: var(--red); color: #fff; text-decoration: none; white-space: nowrap;
    padding: 11px 24px; border-radius: 10px; font-weight: 700; font-size: 0.9rem;
    transition: background 0.2s, transform 0.2s;
  }
  .squads-xlink a:hover { background: var(--red-dark); transform: translateY(-2px); }

  /* COACHES */
  .coaches { background: #fff; }
  .coaches-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 44px; }
  .coach-card { background: #fff; border-radius: 16px; border: 1.5px solid var(--border); overflow: hidden; text-align: center; transition: all 0.2s; }
  .coach-card:hover { border-color: var(--red); box-shadow: 0 8px 30px rgba(220,38,38,0.1); transform: translateY(-3px); }
  .coach-photo { aspect-ratio: 4 / 5; overflow: hidden; background: #f1f5f9; }
  .coach-photo img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
  .coach-card:hover .coach-photo img { transform: scale(1.05); }
  .coach-card h3 { font-size: 1rem; font-weight: 800; margin: 14px 0 2px; }
  .coach-role { font-size: 0.78rem; font-weight: 600; color: var(--red); margin: 0 0 16px; }
  .volunteer-note { margin-top: 36px; color: var(--muted); font-size: 0.92rem; line-height: 1.7; max-width: 760px; }

  /* CTA */
  .page-cta { background: linear-gradient(135deg, var(--red-dark), var(--red)); text-align: center; padding: 72px 5vw; }
  .page-cta h2 { color: #fff; margin-bottom: 12px; }
  .page-cta p { color: rgba(255,255,255,0.9); max-width: 480px; margin: 0 auto 28px; line-height: 1.7; }
  .btn-white { background: #000; color: #fff; padding: 13px 28px; border-radius: 8px; font-weight: 700; font-size: 0.95rem; text-decoration: none; transition: all 0.2s; display: inline-block; }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); background: #222; }

  @media (max-width: 1000px) {
    .squad-times-grid { grid-template-columns: 1fr; }
    .coaches-grid { grid-template-columns: repeat(2, 1fr); }
    .sub-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .coaches-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
    .sub-cards { grid-template-columns: 1fr; }
    .inner { padding: 0; }
  }
</style>
