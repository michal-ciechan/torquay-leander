---
interface Props {
  title?: string;
  message?: string;
}
const { title = 'Coming Soon', message = 'This page is currently under construction. Check back soon.' } = Astro.props;
---
<section class="uc-section">
  <div class="uc-inner">
    <div class="uc-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="6" width="20" height="12" rx="2"/>
        <path d="M12 12h.01"/>
        <path d="M2 10h20"/>
        <path d="M7 6V4"/>
        <path d="M17 6V4"/>
        <path d="M8 14l2 2 4-4"/>
      </svg>
    </div>
    <h2>{title}</h2>
    <p>{message}</p>
    <div class="uc-stripes" aria-hidden="true"></div>
  </div>
</section>

<style>
  .uc-section {
    padding: 100px 5vw;
    background: #fafafa;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .uc-inner {
    text-align: center;
    max-width: 520px;
    position: relative;
  }
  .uc-icon {
    color: var(--red);
    margin-bottom: 24px;
    opacity: 0.85;
  }
  .uc-inner h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--black);
    margin: 0 0 12px;
  }
  .uc-inner p {
    font-size: 1.05rem;
    color: var(--muted);
    margin: 0 0 32px;
    line-height: 1.7;
  }
  .uc-stripes {
    height: 8px;
    border-radius: 4px;
    background: repeating-linear-gradient(
      -45deg,
      var(--red) 0px,
      var(--red) 10px,
      #ffd700 10px,
      #ffd700 20px
    );
    opacity: 0.5;
  }
</style>
