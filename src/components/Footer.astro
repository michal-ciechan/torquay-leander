---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logo = 'https://torquayleander.co.uk/wp-content/uploads/2021/07/Logo.png';
---
<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="f-logo">
          <img src={logo} alt="" onerror="this.style.display='none'" />
          <span>Torquay Leander</span>
        </div>
        <p>A non-profit, SwimMark registered swimming club in Torquay, Devon. Swim England affiliated. Open to all ages and abilities.</p>
      </div>
      <div class="footer-col">
        <h4>Club</h4>
        <ul>
          <li><a href={`${base}/about/`}>About Us</a></li>
          <li><a href={`${base}/about/squads/`}>Our Squads</a></li>
          <li><a href={`${base}/membership/`}>Membership</a></li>
          <li><a href={`${base}/about/facilities/`}>Our Facilities</a></li>
          <li><a href={`${base}/about/join/`}>Join Us</a></li>
          <li><a href={`${base}/about/codes-of-conduct/`}>Codes of Conduct</a></li>
          <li><a href={`${base}/safeguarding/`}>Safeguarding &amp; Welfare</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Swimming</h4>
        <ul>
          <li><a href={`${base}/training/`}>Training</a></li>
          <li><a href={`${base}/training/#timetable`}>Training Timetable</a></li>
          <li><a href={`${base}/training/#coaches`}>Our Coaches</a></li>
          <li><a href={`${base}/training/equipment/`}>Training Equipment</a></li>
          <li><a href={`${base}/training/learn-to-swim/`}>Learn to Swim</a></li>
          <li><a href={`${base}/galas/`}>Galas &amp; Competitions</a></li>
          <li><a href={`${base}/merchandise/`}>Club Merchandise</a></li>
        </ul>
      </div>
      <div class="footer-col footer-contact">
        <h4>Contact</h4>
        <ul>
          <li>
            <a href="mailto:torquayleander@hotmail.com">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              torquayleander@hotmail.com
            </a>
          </li>
          <li class="contact-address">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="addr">Swim Torquay<br />Plainmoor, Torquay<br />Devon, UK</span>
          </li>
          <li>
            <a href="https://www.facebook.com/TorquayLeanderSwimmingClub" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
          </li>
          <li>
            <a href={`${base}/login/`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
              Members Login
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-sponsors">
      <span class="footer-sponsors-label">Our Sponsors</span>
      <div class="footer-sponsors-logos">
        <a href="https://www.sparkworld.co.uk" target="_blank" rel="noopener">
          <img src={`${base}/sponsors/sparkworld-nav.svg`} alt="Sparkworld" />
        </a>
        <a href="https://www.safeheat.co.uk" target="_blank" rel="noopener">
          <img src={`${base}/sponsors/safeheat-nav.svg`} alt="Safeheat" />
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 Torquay Leander Swimming Club. All rights reserved.</span>
      <span>Non-profit &middot; SwimMark Registered &middot; Swim England Affiliated</span>
    </div>
  </div>
</footer>

<style>
  .footer-contact a { display: inline-flex; align-items: center; gap: 9px; }
  .footer-contact .contact-address { display: flex; align-items: flex-start; gap: 9px; color: rgba(255,255,255,0.6); }
  .footer-contact svg { flex-shrink: 0; width: 15px; height: 15px; opacity: 0.85; }
  .footer-contact .contact-address svg { margin-top: 3px; }
  .footer-contact .addr { line-height: 1.55; font-size: 0.88rem; }

  .footer-sponsors {
    display: flex; align-items: center; justify-content: center; gap: 28px; flex-wrap: wrap;
    padding: 28px 0; margin-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .footer-sponsors-label {
    color: rgba(255,255,255,0.45); font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
  }
  .footer-sponsors-logos { display: flex; align-items: center; gap: 36px; flex-wrap: wrap; }
  .footer-sponsors-logos a { display: block; }
  .footer-sponsors-logos img {
    height: 34px; width: auto; object-fit: contain; display: block;
    opacity: 0.75; filter: grayscale(1); transition: opacity 0.2s, filter 0.2s;
  }
  .footer-sponsors-logos a:hover img { opacity: 1; filter: grayscale(0); }
</style>
